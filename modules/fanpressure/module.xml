<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE module SYSTEM "../module.dtd">
<module version="1.0.0">

    <admin>
        <adminpage id="fanpressure_admin" permissionrole="r_daten" navcategory="league" filename="fanpressure-admin" />
    </admin>

    <dependencies>
        <dependency module="clubs" version="1.0.0"/>
        <dependency module="office" version="1.0.0"/>
        <dependency module="notifications" version="1.0.0"/>
        <dependency module="news" version="1.0.0"/>
        <dependency module="sponsor" version="1.0.0"/>
    </dependencies>

    <settings>
        <setting id="fanpressure_enabled" category="game" type="boolean" default="1" />
        <setting id="fanpressure_attendance_max_effect" category="game" type="number" default="8" />
        <setting id="fanpressure_sponsor_max_effect" category="game" type="number" default="10" />
        <setting id="fanpressure_notification_threshold" category="game" type="number" default="6" />
        <setting id="fanpressure_create_extreme_news" category="game" type="boolean" default="1" />
        <setting id="fanpressure_interview_expiry_days" category="game" type="number" default="7" />
    </settings>

    <pages>
        <page
            id="fanpressure"
            template="fanpressure"
            model="FanPressureModel"
            parentItem="office"
            navitem="true"
            navweight="9"
            role="user"
            navitemOnlyForConfigEnabled="fanpressure_enabled">
        </page>
    </pages>

    <actions>
        <action id="answer-fanpressure-interview" controller="AnswerFanPressureInterviewController" role="user" log="true">
            <param id="occurrence_id" type="number" required="true" />
            <param id="answer" type="text" required="true" max="1" />
        </action>
    </actions>

    <plugins>
        <eventlistener event="MatchCompletedEvent" class="FanPressurePlugin" method="handleMatchCompleted" />
        <eventlistener event="TicketsComputedEvent" class="FanPressurePlugin" method="adjustAttendance" />
    </plugins>

</module>
