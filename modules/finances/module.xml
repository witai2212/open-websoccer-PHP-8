<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE module SYSTEM "../module.dtd">
<module version="1.0.0">

    <settings>
        <setting id="bank_loans_enabled" category="game" type="boolean" default="1" />
    </settings>
  

    <admin>
        <adminpage
            id="bankloans"
            entity="bankloans"
            navcategory="league"
            permissionrole="r_daten" >

            <entity dbtable="bank AS BankLoan" >

                <overview delete="false" edit="true" add="false" >
                    <column id="entity_bankloans_id" field="BankLoan.id" type="number" sort="true" />
                    <column id="entity_bankloans_verein_id" field="BankLoan.verein_id" type="number" sort="true" />
                    <column id="entity_bankloans_original_amount" field="BankLoan.original_amount" type="number" sort="true" />
                    <column id="entity_bankloans_remaining_amount" field="BankLoan.remaining_amount" type="number" sort="true" />
                    <column id="entity_bankloans_interest_rate" field="BankLoan.interest_rate" type="percent" sort="true" />
                    <column id="entity_bankloans_matches_left" field="BankLoan.matches_left" type="number" sort="true" />
                    <column id="entity_bankloans_status" field="BankLoan.status" type="text" sort="true" />
                    <column id="entity_bankloans_credit_rating" field="BankLoan.credit_rating" type="text" sort="true" />
                    <column id="entity_bankloans_created_date" field="BankLoan.created_date" type="timestamp" sort="true" />
                </overview>

                <editform>
                    <field id="original_amount" type="number" required="true" />
                    <field id="remaining_principal" type="number" required="true" />
                    <field id="interest_rate" type="number" required="true" />
                    <field id="remaining_interest" type="number" required="true" />
                    <field id="remaining_amount" type="number" required="true" />
                    <field id="matches_left" type="number" required="true" />
                    <field id="status" type="select" selection="active,repaid,defaulted" required="true" />
                    <field id="board_warning_sent" type="select" selection="1,0" required="true" />
                </editform>
            </entity>
        </adminpage>
    </admin>

    <pages>
        <page
            id="finance"
            template="finances"
            model="FinancesModel"
            navitem="true"
            navweight="2"
            role="user">
			<page
	            id="stockmarket"
	            template="stockmarket"
	            navitem="true"
	            model="StockMarketModel"
	            navweight="5"
	            role="user">
	        
		        <page
		            id="buystock"
		            template="buystock"
		            model="BuyStockModel"
		            role="user">
		         </page>
	        
		        <page
		            id="sellstock"
		            template="sellstock"
		            model="SellStockModel"
		            role="user">
		         </page>
			
    			<page
    				id="stock_chart"
    				template="stock_chart"
    				model="StockChartModel"
    				parentItem="portfolio"
    				role="user">
    				<script file="flot/jquery.flot.min.js" />
    				<script file="charts.js" />
    				<script file="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.cjs"/>
    				<css file="charts.css"/>
    			 </page>
			</page>

	        <page
	            id="financialforecast"
	            template="financialforecast"
	            model="FinancialForecastModel"
	            navitem="true"
	            navweight="4"
	            role="user">
	        </page>
			
	        <page
	            id="bank-loans"
	            template="bank-loans"
	            model="BankLoansModel"
	            navitem="true"
	            navweight="2"
	            parentItem="finance"
	            role="user"
	            navitemOnlyForConfigEnabled="bank_loans_enabled">
	        </page>

	        <page
	            id="portfolio"
	            template="portfolio"
	            model="MyPortfolioModel"
	            navitem="true"
	            navweight="3"
	            parentItem="stockmarket"
	            role="user">
	        
	        </page>
			
        </page>
    </pages>
	
	<blocks>
        <block
            id="account_statement"
            template="account_statement"
            model="FinancesModel"
            includepages="none"
            area="custom"
            role="user" />
	</blocks>
    
	<actions>
		<action id="buy_stock" controller="BuyStockController" role="user">
			<param id="index" type="text" min="1" max="10000000" required="true" />
			<param id="qty" type="text" min="1" max="100000000" required="true" />
		</action>
		<action id="sell_stock" controller="SellStockController" role="user">
			<param id="index" type="text" min="1" max="10000000" required="true" />
			<param id="qty" type="text" min="1" max="100000000" required="true" />
			<param id="max_qty" type="text" min="1" max="100000000" required="true" />
		</action>
		
        <action id="take-bank-loan" controller="TakeBankLoanController" role="user">
            <param id="offer_key" type="text" min="1" max="16" required="true" />
        </action>
        <action id="repay-bank-loan" controller="RepayBankLoanController" role="user">
            <param id="loan_id" type="number" min="1" max="100000000" required="true" />
        </action>

	</actions>    
    

    <plugins>
        <eventlistener event="MatchCompletedEvent" class="BankLoansPlugin" method="handleMatchCompleted" />
    </plugins>

</module>