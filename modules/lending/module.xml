<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE module SYSTEM "../module.dtd">
<module version="1.1.0">

    <dependencies>
        <dependency module="players" version="1.0.0"/>
    </dependencies>
    
	<settings>
	    <setting id="lending_enabled" category="game" type="boolean" default="1" />
	    <setting id="lending_matches_min" category="game" type="number" default="5" />
	    <setting id="lending_matches_max" category="game" type="number" default="20" />
	    <setting id="lending_cpu_offer_duration_days" category="game" type="number" default="10" />
	    <setting id="lending_cpu_offer_cooldown_days" category="game" type="number" default="20" />
	    <setting id="lending_cpu_request_expiry_days" category="game" type="number" default="10" />
	</settings>
	
    <pages>
        <page
            id="loans"
            template="loan-overview"
            model="LoanOverviewModel"
            role="user"
            parentItem="transfermarket"
            navitem="true"
            navweight="20"
            navitemOnlyForConfigEnabled="lending_enabled" />

        <page
            id="lend-player"
            template="lend-player"
            model="LoanPlayerDetailsModel"
            role="user"
            parentItem="transfermarket" />
        
        <page
            id="borrow-player"
            template="borrow-player"
            model="LoanPlayerDetailsModel"
            role="user"
            parentItem="transfermarket" />
   
    </pages>
    
    <blocks>
        <block id="lent-players"
            template="lent_players"
            model="LentPlayersModel"
            role="user"
            includepages="none"
            area="custom" />
    </blocks>
    
  <actions>
	<action id="lend-player" controller="LendPlayerController" role="user">
		<param id="fee" type="number" required="true" min="1" max="1000000000" />
		<param id="salary_share_percent" type="number" required="false" min="50" max="100" />
		<param id="option_type" type="text" required="false" />
		<param id="buy_fee" type="number" required="false" min="0" max="1000000000" />
		<param id="id" type="number" required="true" />
	</action>
	
	<action id="unmarkLendable" controller="UnmarkLendableController" role="user">
		<param id="id" type="number" required="true" />
	</action>
	
	<action id="borrow-player" controller="BorrowPlayerController" role="user">
		<param id="matches" type="number" required="true" min="1" max="100" />
		<param id="id" type="number" required="true" />
	</action>

	<action id="accept-loan-request" controller="AcceptLoanRequestController" role="user">
		<param id="id" type="number" required="true" />
	</action>

	<action id="reject-loan-request" controller="RejectLoanRequestController" role="user">
		<param id="id" type="number" required="true" />
	</action>

	<action id="recall-loan" controller="RecallLoanController" role="user">
		<param id="id" type="number" required="true" />
	</action>

	<action id="buy-loan-player" controller="BuyLoanPlayerController" role="user">
		<param id="id" type="number" required="true" />
	</action>
	
  </actions>
	
</module>
