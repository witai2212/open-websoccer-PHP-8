<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE module SYSTEM "../module.dtd">
<module version="1.1.0">

  <dependencies>
    <dependency module="users" version="1.0.0"/>
    <dependency module="freeclubs" version="1.0.0"/>
    <dependency module="office" version="1.0.0"/>
  </dependencies>

  <admin>
    <adminpage id="managercareer_admin" permissionrole="r_daten" navcategory="league" filename="manager-career-admin" />
  </admin>

  <settings>
    <setting id="mgr_career_enabled" category="game" type="boolean" default="1" />
    <setting id="mgr_job_offers" category="game" type="boolean" default="1" />
    <setting id="freeclub_rep_check" category="game" type="boolean" default="1" />
    <setting id="mgr_offer_limit" category="game" type="number" default="3" />
    <setting id="mgr_offer_exp_days" category="game" type="number" default="21" />
    <setting id="mgr_applications_enabled" category="game" type="boolean" default="1" />
    <setting id="mgr_application_limit" category="game" type="number" default="3" />
    <setting id="mgr_application_decision_min_days" category="game" type="number" default="3" />
    <setting id="mgr_application_decision_max_days" category="game" type="number" default="7" />
    <setting id="mgr_application_exp_days" category="game" type="number" default="14" />
    <setting id="mgr_auto_sacking_enabled" category="game" type="boolean" default="1" />
    <setting id="mgr_contract_days" category="game" type="number" default="180" />
  </settings>

  <pages>
    <page
      id="managercareer"
      template="manager-career"
      model="ManagerCareerModel"
      parentItem="office"
      navitem="true"
      navweight="7"
      role="user"
      navitemOnlyForConfigEnabled="mgr_career_enabled">
    </page>
  </pages>

  <actions>
    <action id="accept-manager-job" controller="AcceptManagerJobController" role="user">
      <param id="offerId" type="number" required="true" />
    </action>

    <action id="decline-manager-job" controller="DeclineManagerJobController" role="user">
      <param id="offerId" type="number" required="true" />
    </action>

    <action id="switch-free-club" controller="SwitchFreeClubController" role="user">
      <param id="teamId" type="number" required="true" />
    </action>

    <action id="apply-manager-job" controller="ApplyManagerJobController" role="user">
      <param id="teamId" type="number" required="true" />
    </action>

    <action id="withdraw-manager-application" controller="WithdrawManagerApplicationController" role="user">
      <param id="applicationId" type="number" required="true" />
    </action>

  </actions>

</module>
