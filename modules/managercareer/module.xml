<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE module SYSTEM "../module.dtd">
<module version="1.0.0">

  <dependencies>
    <dependency module="users" version="1.0.0"/>
    <dependency module="freeclubs" version="1.0.0"/>
  </dependencies>

  <settings>
    <setting id="mgr_career_enabled" category="game" type="boolean" default="1" />
    <setting id="mgr_job_offers" category="game" type="boolean" default="1" />
    <setting id="freeclub_rep_check" category="game" type="boolean" default="1" />
    <setting id="mgr_offer_limit" category="game" type="number" default="3" />
    <setting id="mgr_offer_exp_days" category="game" type="number" default="21" />
  </settings>

  <actions>
    <action id="accept-manager-job" controller="AcceptManagerJobController" role="user">
      <param id="offerId" type="number" required="true" />
    </action>

    <action id="decline-manager-job" controller="DeclineManagerJobController" role="user">
      <param id="offerId" type="number" required="true" />
    </action>

    <action id="switch-free-club" controller="SwitchFreeClubController" role="user">
      <param id="teamId" type="number" required="true" />
    </action>

  </actions>

</module>
