<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE module SYSTEM "../module.dtd">
<module version="1.0.0">

    <dependencies>
        <dependency module="clubs" version="1.0.0"/>
        <dependency module="office" version="1.0.0"/>
        <dependency module="formation" version="1.0.0"/>
        <dependency module="clubstaff" version="1.0.0"/>
        <dependency module="stadiumenvironment" version="1.0.0"/>
    </dependencies>

    <settings>
        <setting id="medcenter_enabled" category="game" type="boolean" default="1" />
        <setting id="medcenter_physio_fee" category="game" type="number" default="25000" />
        <setting id="medcenter_spec_fee" category="game" type="number" default="100000" />
        <setting id="medcenter_risk_fee" category="game" type="number" default="250000" />
        <setting id="medcenter_detect_pct" category="game" type="number" default="15" />
    </settings>

    <pages>
        <page
            id="medical-center"
            template="medical-center"
            model="MedicalCenterModel"
            parentItem="office"
            navitem="true"
            navweight="9"
            role="user"
            navitemOnlyForConfigEnabled="medcenter_enabled">
        </page>
    </pages>

    <actions>
        <action id="apply-medical-treatment" controller="ApplyMedicalTreatmentController" role="user" log="true">
            <param id="id" type="number" required="true" min="1" max="2000000000" />
            <param id="treatment" type="text" required="true" min="3" max="64" />
        </action>

        <action id="clear-player-risk" controller="ClearPlayerRiskController" role="user" log="true">
            <param id="id" type="number" required="true" min="1" max="2000000000" />
        </action>
    </actions>

    <plugins>
        <eventlistener event="MatchCompletedEvent" class="MedicalCenterPlugin" method="handleMatchCompleted" />
    </plugins>

</module>
