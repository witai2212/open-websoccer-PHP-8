<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE module SYSTEM "../module.dtd">
<module version="1.0.0">

    <dependencies>
        <dependency module="clubs" version="1.0.0"/>
        <dependency module="myteam" version="1.0.0"/>
    </dependencies>

    <settings>
        <setting id="team_chemistry_enabled" category="game" type="boolean" default="1" />
        <setting id="team_chemistry_max_match_effect" category="game" type="number" default="3" />
        <setting id="team_chemistry_recent_transfer_days" category="game" type="number" default="30" />
        <setting id="team_chemistry_formation_history_count" category="game" type="number" default="8" />
    </settings>

    <pages>
        <page
            id="teamchemistry"
            template="teamchemistry"
            model="TeamChemistryModel"
            parentItem="myteam"
            navitem="true"
            navweight="6"
            role="user">
        </page>
    </pages>

    <plugins>
        <eventlistener event="MatchCompletedEvent" class="TeamChemistryPlugin" method="handleMatchCompleted" />
    </plugins>

</module>
