{% if statement_groups|length == 0 %}
    <p class="muted">{{ i18n.getMessage("account_statement_no_entries") }}</p>
{% else %}
    <div class="btn-group" style="margin-bottom:12px">
        <button type="button" class="btn btn-small account-statement-open-all"><i class="icon-folder-open"></i> {{ i18n.getMessage("account_statement_open_all") }}</button>
        <button type="button" class="btn btn-small account-statement-close-all"><i class="icon-folder-close"></i> {{ i18n.getMessage("account_statement_close_all") }}</button>
    </div>

    <div class="accordion account-statement-groups" id="accountStatementGroups">
    {% for group in statement_groups %}
        <div class="accordion-group">
            <div class="accordion-heading">
                <a class="accordion-toggle" data-toggle="collapse" href="#accountStatementDay{{ group.key }}">
                    <div class="row-fluid">
                        <div class="span3"><i class="icon-calendar"></i> <strong>{{ env.getFormattedDate(group.date) }}</strong></div>
                        <div class="span3 text-right"><span class="text-success">+{{ group.revenues|number_format(0, ',', ' ') }} {{ env.getConfig("game_currency") }}</span></div>
                        <div class="span3 text-right"><span class="text-error">{{ group.expenses|number_format(0, ',', ' ') }} {{ env.getConfig("game_currency") }}</span></div>
                        <div class="span3 text-right">
                            {% if group.balance >= 0 %}<strong class="text-success">+{{ group.balance|number_format(0, ',', ' ') }} {{ env.getConfig("game_currency") }}</strong>{% else %}<strong class="text-error">{{ group.balance|number_format(0, ',', ' ') }} {{ env.getConfig("game_currency") }}</strong>{% endif %}
                        </div>
                    </div>
                    <div class="row-fluid muted" style="font-size:11px;margin-top:3px">
                        <div class="span3">{{ i18n.getMessage("account_statement_date") }}</div>
                        <div class="span3 text-right">{{ i18n.getMessage("account_statement_revenues") }}</div>
                        <div class="span3 text-right">{{ i18n.getMessage("account_statement_expenses") }}</div>
                        <div class="span3 text-right">{{ i18n.getMessage("account_statement_daily_balance") }}</div>
                    </div>
                </a>
            </div>
            <div id="accountStatementDay{{ group.key }}" class="accordion-body collapse{% if loop.first %} in{% endif %}">
                <div class="accordion-inner" style="padding:0">
                    <table class="table table-striped table-condensed" style="margin-bottom:0">
                        <thead>
                            <tr>
                                <th>{{ i18n.getMessage("account_statement_sender") }}</th>
                                <th>{{ i18n.getMessage("account_statement_subject") }}</th>
                                <th class="text-right">{{ i18n.getMessage("account_statement_amount") }}</th>
                            </tr>
                        </thead>
                        <tbody>
                        {% for statement in group.statements %}
                            <tr>
                                <td>{% if i18n.hasMessage(statement.sender) %}{{ i18n.getMessage(statement.sender) }}{% else %}{{ statement.sender }}{% endif %}</td>
                                <td>{% if i18n.hasMessage(statement.subject) %}{{ i18n.getMessage(statement.subject) }}{% else %}{{ statement.subject }}{% endif %}</td>
                                <td class="text-right">
                                    {% if statement.amount >= 0 %}<span class="text-success">+{{ statement.amount|number_format(0, ',', ' ') }} {{ env.getConfig("game_currency") }}</span>{% else %}<span class="text-error">{{ statement.amount|number_format(0, ',', ' ') }} {{ env.getConfig("game_currency") }}</span>{% endif %}
                                </td>
                            </tr>
                        {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    {% endfor %}
    </div>
{% endif %}

{{ pagination.paginator(paginator) }}

<script>
(function($) {
    $('.account-statement-open-all').off('click.accountStatement').on('click.accountStatement', function() {
        $('.account-statement-groups .accordion-body').collapse('show');
    });
    $('.account-statement-close-all').off('click.accountStatement').on('click.accountStatement', function() {
        $('.account-statement-groups .accordion-body').collapse('hide');
    });
})(jQuery);
</script>
