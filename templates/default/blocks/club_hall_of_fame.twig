{% import "macros/messagebox.twig" as messagebox %}

{% set has_data = titles|length > 0 or summary.matches > 0 or best_players|length > 0 or top_scorers|length > 0 or top_assists|length > 0 or most_appearances|length > 0 or highest_win or worst_defeat or record_incoming_transfer or record_outgoing_transfer or league_positions|length > 0 %}

{% if not has_data %}
	{{ messagebox.box("", i18n.getMessage("club_hof_no_data"), "info") }}
{% else %}

	<h4>{{ i18n.getMessage("club_hof_overview") }}</h4>
	<div class="row-fluid">
		<div class="span3 well" style="text-align: center; min-height: 90px;">
			<div class="muted">{{ i18n.getMessage("club_hof_titles") }}</div>
			<strong style="font-size: 24px;">{{ titles_count }}</strong>
		</div>
		<div class="span3 well" style="text-align: center; min-height: 90px;">
			<div class="muted">{{ i18n.getMessage("club_hof_official_matches") }}</div>
			<strong style="font-size: 24px;">{{ summary.matches|default(0) }}</strong>
		</div>
		<div class="span3 well" style="text-align: center; min-height: 90px;">
			<div class="muted">{{ i18n.getMessage("club_hof_balance") }}</div>
			<strong style="font-size: 18px;">{{ summary.wins|default(0) }} / {{ summary.draws|default(0) }} / {{ summary.losses|default(0) }}</strong>
			<br><small>{{ i18n.getMessage("club_hof_wdl") }}</small>
		</div>
		<div class="span3 well" style="text-align: center; min-height: 90px;">
			<div class="muted">{{ i18n.getMessage("club_hof_goals") }}</div>
			<strong style="font-size: 18px;">{{ summary.goals_for|default(0) }} : {{ summary.goals_against|default(0) }}</strong>
		</div>
	</div>

	<div class="row-fluid">
		<div class="span6">
			<h4>{{ i18n.getMessage("club_hof_highest_win") }}</h4>
			{% if highest_win %}
				<p>
					<a href="{{ env.getInternalUrl("match", "id=" ~ highest_win.match_id) }}"><strong>{{ highest_win.home_name }} {{ highest_win.home_goals }}:{{ highest_win.guest_goals }} {{ highest_win.guest_name }}</strong></a><br>
					<small class="muted">{{ env.getFormattedDate(highest_win.match_date) }}{% if highest_win.league_name|length > 0 %}, {{ highest_win.league_name }}{% elseif highest_win.cup_name|length > 0 %}, {{ highest_win.cup_name }}{% endif %}</small>
				</p>
			{% else %}
				<p class="muted">{{ i18n.getMessage("club_hof_no_record") }}</p>
			{% endif %}
		</div>
		<div class="span6">
			<h4>{{ i18n.getMessage("club_hof_worst_defeat") }}</h4>
			{% if worst_defeat %}
				<p>
					<a href="{{ env.getInternalUrl("match", "id=" ~ worst_defeat.match_id) }}"><strong>{{ worst_defeat.home_name }} {{ worst_defeat.home_goals }}:{{ worst_defeat.guest_goals }} {{ worst_defeat.guest_name }}</strong></a><br>
					<small class="muted">{{ env.getFormattedDate(worst_defeat.match_date) }}{% if worst_defeat.league_name|length > 0 %}, {{ worst_defeat.league_name }}{% elseif worst_defeat.cup_name|length > 0 %}, {{ worst_defeat.cup_name }}{% endif %}</small>
				</p>
			{% else %}
				<p class="muted">{{ i18n.getMessage("club_hof_no_record") }}</p>
			{% endif %}
		</div>
	</div>

	<h4>{{ i18n.getMessage("club_hof_titles") }}</h4>
	{% if titles|length > 0 %}
		<table class="table table-striped table-condensed">
			<thead>
				<tr>
					<th>{{ i18n.getMessage("club_hof_competition") }}</th>
					<th>{{ i18n.getMessage("entity_season") }}</th>
				</tr>
			</thead>
			<tbody>
			{% for title in titles %}
				<tr>
					<td>{{ title.competition }}</td>
					<td>{% if title.saison_name|length > 0 %}{{ title.saison_name }}{% else %}-{% endif %}</td>
				</tr>
			{% endfor %}
			</tbody>
		</table>
	{% else %}
		<p class="muted">{{ i18n.getMessage("club_hof_no_titles") }}</p>
	{% endif %}

	<h4>{{ i18n.getMessage("club_hof_best_players") }}</h4>
	<p class="muted">{{ i18n.getMessage("club_hof_best_players_min_matches", best_players_min_matches) }}</p>
	{% if best_players|length > 0 %}
		<table class="table table-striped table-condensed">
			<thead>
				<tr>
					<th>#</th>
					<th>{{ i18n.getMessage("entity_player") }}</th>
					<th>{{ i18n.getMessage("club_hof_matches") }}</th>
					<th>{{ i18n.getMessage("club_hof_goals_short") }}</th>
					<th>{{ i18n.getMessage("club_hof_assists_short") }}</th>
					<th>{{ i18n.getMessage("club_hof_avg_grade") }}</th>
				</tr>
			</thead>
			<tbody>
			{% for player in best_players %}
				<tr>
					<td>{{ loop.index }}</td>
					<td><a href="{{ env.getInternalUrl("player", "id=" ~ player.player_id) }}">{{ player.player_name }}</a></td>
					<td>{{ player.matches }}</td>
					<td>{{ player.goals|default(0) }}</td>
					<td>{{ player.assists|default(0) }}</td>
					<td>{{ player.avg_grade|number_format(2, ',', ' ') }}</td>
				</tr>
			{% endfor %}
			</tbody>
		</table>
	{% else %}
		<p class="muted">{{ i18n.getMessage("club_hof_no_players") }}</p>
	{% endif %}

	<div class="row-fluid">
		<div class="span4">
			<h4>{{ i18n.getMessage("club_hof_most_goals") }}</h4>
			{% if top_scorers|length > 0 %}
				<table class="table table-striped table-condensed">
					<thead><tr><th>{{ i18n.getMessage("entity_player") }}</th><th>{{ i18n.getMessage("club_hof_goals_short") }}</th></tr></thead>
					<tbody>
					{% for player in top_scorers %}
						<tr><td><a href="{{ env.getInternalUrl("player", "id=" ~ player.player_id) }}">{{ player.player_name }}</a></td><td>{{ player.goals }}</td></tr>
					{% endfor %}
					</tbody>
				</table>
			{% else %}
				<p class="muted">{{ i18n.getMessage("club_hof_no_record") }}</p>
			{% endif %}
		</div>
		<div class="span4">
			<h4>{{ i18n.getMessage("club_hof_most_assists") }}</h4>
			{% if top_assists|length > 0 %}
				<table class="table table-striped table-condensed">
					<thead><tr><th>{{ i18n.getMessage("entity_player") }}</th><th>{{ i18n.getMessage("club_hof_assists_short") }}</th></tr></thead>
					<tbody>
					{% for player in top_assists %}
						<tr><td><a href="{{ env.getInternalUrl("player", "id=" ~ player.player_id) }}">{{ player.player_name }}</a></td><td>{{ player.assists }}</td></tr>
					{% endfor %}
					</tbody>
				</table>
			{% else %}
				<p class="muted">{{ i18n.getMessage("club_hof_no_record") }}</p>
			{% endif %}
		</div>
		<div class="span4">
			<h4>{{ i18n.getMessage("club_hof_most_appearances") }}</h4>
			{% if most_appearances|length > 0 %}
				<table class="table table-striped table-condensed">
					<thead><tr><th>{{ i18n.getMessage("entity_player") }}</th><th>{{ i18n.getMessage("club_hof_matches") }}</th></tr></thead>
					<tbody>
					{% for player in most_appearances %}
						<tr><td><a href="{{ env.getInternalUrl("player", "id=" ~ player.player_id) }}">{{ player.player_name }}</a></td><td>{{ player.matches }}</td></tr>
					{% endfor %}
					</tbody>
				</table>
			{% else %}
				<p class="muted">{{ i18n.getMessage("club_hof_no_record") }}</p>
			{% endif %}
		</div>
	</div>

	<h4>{{ i18n.getMessage("club_hof_record_transfers") }}</h4>
	<div class="row-fluid">
		<div class="span6">
			<h5>{{ i18n.getMessage("club_hof_record_incoming") }}</h5>
			{% if record_incoming_transfer %}
				<p>
					<a href="{{ env.getInternalUrl("player", "id=" ~ record_incoming_transfer.player_id) }}"><strong>{{ record_incoming_transfer.player_name }}</strong></a><br>
					{{ record_incoming_transfer.amount|number_format(0, ',', ' ') }} {{ env.getConfig("game_currency") }}<br>
					<small class="muted">{{ env.getFormattedDate(record_incoming_transfer.transfer_date) }}{% if record_incoming_transfer.seller_name|length > 0 %}, {{ i18n.getMessage("club_hof_from") }} {{ record_incoming_transfer.seller_name }}{% endif %}</small>
				</p>
			{% else %}
				<p class="muted">{{ i18n.getMessage("club_hof_no_record") }}</p>
			{% endif %}
		</div>
		<div class="span6">
			<h5>{{ i18n.getMessage("club_hof_record_outgoing") }}</h5>
			{% if record_outgoing_transfer %}
				<p>
					<a href="{{ env.getInternalUrl("player", "id=" ~ record_outgoing_transfer.player_id) }}"><strong>{{ record_outgoing_transfer.player_name }}</strong></a><br>
					{{ record_outgoing_transfer.amount|number_format(0, ',', ' ') }} {{ env.getConfig("game_currency") }}<br>
					<small class="muted">{{ env.getFormattedDate(record_outgoing_transfer.transfer_date) }}{% if record_outgoing_transfer.buyer_name|length > 0 %}, {{ i18n.getMessage("club_hof_to") }} {{ record_outgoing_transfer.buyer_name }}{% endif %}</small>
				</p>
			{% else %}
				<p class="muted">{{ i18n.getMessage("club_hof_no_record") }}</p>
			{% endif %}
		</div>
	</div>

	<h4>{{ i18n.getMessage("club_hof_league_positions") }}</h4>
	{% if league_positions|length > 0 %}
		<table class="table table-striped table-condensed">
			<thead>
				<tr>
					<th>{{ i18n.getMessage("entity_season") }}</th>
					<th>{{ i18n.getMessage("entity_league") }}</th>
					<th>{{ i18n.getMessage("leaguetable_head_place") }}</th>
					<th>{{ i18n.getMessage("entity_users") }}</th>
				</tr>
			</thead>
			<tbody>
			{% for position in league_positions %}
				<tr>
					<td>{{ position.season_name }} <small class="muted">({{ i18n.getMessage("club_hof_matchday", position.matchday) }})</small></td>
					<td>{{ position.league_name }}</td>
					<td>{{ position.rank }}</td>
					<td>{% if position.user_id > 0 %}<a href="{{ env.getInternalUrl("user", "id=" ~ position.user_id) }}">{{ position.user_name }}</a>{% else %}-{% endif %}</td>
				</tr>
			{% endfor %}
			</tbody>
		</table>
	{% else %}
		<p class="muted">{{ i18n.getMessage("club_hof_no_league_positions") }}</p>
	{% endif %}

{% endif %}
