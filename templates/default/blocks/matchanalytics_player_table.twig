<table class="table table-striped table-condensed">
    <thead>
        <tr>
            <th>{{ i18n.getMessage("match_details_players_name") }}</th>
            <th>{{ i18n.getMessage("matchanalytics_minutes_short") }}</th>
            <th>{{ i18n.getMessage("match_details_players_grade") }}</th>
            <th>{{ i18n.getMessage("matchanalytics_trend") }}</th>
            <th>{{ i18n.getMessage("matchanalytics_pass_success_short") }}</th>
            <th>{{ i18n.getMessage("matchanalytics_tackles_short") }}</th>
            <th>{{ i18n.getMessage("matchanalytics_shots_short") }}</th>
            <th>{{ i18n.getMessage("matchanalytics_ballcontacts_short") }}</th>
            <th>{{ i18n.getMessage("matchanalytics_assists_short") }}</th>
            <th>{{ i18n.getMessage("matchanalytics_freekicks_short") }}</th>
        </tr>
    </thead>
    <tbody>
        {% for player in players %}
            <tr {% if player.minutesPlayed < 1 %}class="muted"{% endif %}>
                <td>
                    <a href="{{ env.getInternalUrl("player", "id=" ~ player.id) }}">{{ player.display_name }}</a>
                    {% if player.position_main|length > 0 %}<br><small>{{ player.position_main }}</small>{% endif %}
                    {% if player.minutesPlayed < 1 %}<br><small>{{ i18n.getMessage("matchanalytics_bench") }}</small>{% endif %}
                </td>
                <td>{{ player.minutesPlayed }}</td>
                <td>{% if player.grade > 0 %}{{ player.grade|number_format(2, ',', ' ') }}{% else %}-{% endif %}</td>
                <td>
                    {% if player.grade_average > 0 and player.grade > 0 %}
                        {% if player.grade_difference_average < -0.05 %}
                            <span class="label label-success">{{ i18n.getMessage("matchanalytics_trend_better") }}</span>
                        {% elseif player.grade_difference_average > 0.05 %}
                            <span class="label label-important">{{ i18n.getMessage("matchanalytics_trend_worse") }}</span>
                        {% else %}
                            <span class="label">{{ i18n.getMessage("matchanalytics_trend_stable") }}</span>
                        {% endif %}
                        <br><small>{{ player.grade_difference_average|number_format(2, ',', ' ') }}</small>
                    {% else %}
                        -
                    {% endif %}
                </td>
                <td>
                    {% if player.passes_total > 0 %}
                        {{ player.pass_success_percent|number_format(1, ',', ' ') }}%<br><small>{{ player.passes_successed }}/{{ player.passes_failed }}</small>
                    {% else %}
                        -
                    {% endif %}
                </td>
                <td>
                    {% if player.tackles_total > 0 %}
                        {{ player.tackle_success_percent|number_format(1, ',', ' ') }}%<br><small>{{ player.wontackles }}/{{ player.losttackles }}</small>
                    {% else %}
                        -
                    {% endif %}
                </td>
                <td>{{ player.shoots }}</td>
                <td>{{ player.ballcontacts }}</td>
                <td>{{ player.assists }}</td>
                <td>
                    {% if player.freekicks_total > 0 %}
                        {{ player.freekick_success_percent|number_format(1, ',', ' ') }}%<br><small>{{ player.freekicks_successed }}/{{ player.freekicks_failed }}</small>
                    {% else %}
                        -
                    {% endif %}
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="10">{{ i18n.getMessage("matchanalytics_no_player_data") }}</td>
            </tr>
        {% endfor %}
    </tbody>
</table>
