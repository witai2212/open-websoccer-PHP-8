<div class="row-fluid" style="margin-bottom:15px">
    <div class="span4"><div class="well well-small"><strong>{{ offers|length }}</strong><br><span class="muted">{{ i18n.getMessage("transferoffers_tab_received") }}</span></div></div>
    <div class="span4"><div class="well well-small"><strong>{{ bids|length }}</strong><br><span class="muted">{{ i18n.getMessage("transferoffers_tab_sent") }}</span></div></div>
    <div class="span4"><div class="well well-small"><strong>{{ myplayers|length }}</strong><br><span class="muted">{{ i18n.getMessage("myplayers_on_transferlist") }}</span></div></div>
</div>

<ul class="nav nav-pills" id="myOffersTabs">
    <li class="active"><a href="#receivedOffers" data-toggle="tab"><i class="icon-inbox"></i> {{ i18n.getMessage("transferoffers_tab_received") }}</a></li>
    <li><a href="#sentOffers" data-toggle="tab"><i class="icon-share"></i> {{ i18n.getMessage("transferoffers_tab_sent") }}</a></li>
    <li><a href="#listedPlayers" data-toggle="tab"><i class="icon-list"></i> {{ i18n.getMessage("myplayers_on_transferlist") }}</a></li>
</ul>

<div class="tab-content">
    <div class="tab-pane active" id="receivedOffers">
        {% if offers|length == 0 %}
            <div class="alert alert-info">{{ i18n.getMessage("transfermarket_no_received_offers") }}</div>
        {% else %}
        <table class="table table-striped table-hover" id="myoffers-overview-table">
            <thead><tr>
                <th></th>
                <th aria-sort="none"><a href="#receivedOffers" class="myoffers-sort" data-sort-column="player">{{ i18n.getMessage("offertable_head_player") }} <i class="icon-resize-vertical"></i></a></th>
                <th>{{ i18n.getMessage("offertable_head_position") }}</th>
                <th>{{ i18n.getMessage("offertable_head_enddate") }}</th>
                <th aria-sort="none"><a href="#receivedOffers" class="myoffers-sort" data-sort-column="fee">{{ i18n.getMessage("offertable_head_transfer_fee") }} <i class="icon-resize-vertical"></i></a></th>
                <th>{{ i18n.getMessage("offertable_head_market_value") }}</th>
                <th>{{ i18n.getMessage("offertable_bidder") }}</th>
                <th></th>
            </tr></thead>
            <tbody>
            {% for offer in offers %}
                <tr data-original-order="{{ loop.index }}">
                    <td class="myoffers-row-number"><strong>{{ loop.index }}</strong></td>
                    <td data-sort-column="player" data-sort-value="{{ (offer.vorname ~ ' ' ~ offer.nachname)|lower }}"><a href="{{ env.getInternalUrl("player", "id=" ~ offer.spieler_id) }}">{{ offer.vorname }} {{ offer.nachname }}</a></td>
                    <td>{{ offer.position_main }}{% if offer.position_second|length > 0 %} ({{ offer.position_second }}){% endif %}</td>
                    <td>{{ env.getFormattedDatetime(offer.transfer_ende) }}</td>
                    <td data-sort-column="fee" data-sort-value="{{ offer.abloese }}"><strong>{{ offer.abloese|number_format(0, ',', ' ') }} {{ env.getConfig("game_currency") }}</strong></td>
                    <td>{{ offer.marktwert|number_format(0, ',', ' ') }} {{ env.getConfig("game_currency") }}</td>
                    <td>{{ offer.bidder.team_name }}</td>
                    <td style="white-space:nowrap">
                        <a class="btn btn-mini btn-success" href="?page=myoffers&id={{ offer.id }}&action=accept_offer"><i class="icon-thumbs-up"></i> {{ i18n.getMessage("offer_accept") }}</a>
                        <a class="btn btn-mini" href="?page=myoffers&id={{ offer.id }}&action=reject_offer"><i class="icon-thumbs-down"></i> {{ i18n.getMessage("offer_reject") }}</a>
                    </td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
        {% endif %}
    </div>
    <div class="tab-pane" id="sentOffers">
        {% if bids|length > 0 %}{% include "blocks/mybids.twig" %}{% else %}<div class="alert alert-info">{{ i18n.getMessage("transfermarket_no_sent_offers") }}</div>{% endif %}
    </div>
    <div class="tab-pane" id="listedPlayers">
        {% if myplayers|length > 0 %}{% include "blocks/myplayersontl.twig" %}{% else %}<div class="alert alert-info">{{ i18n.getMessage("transfermarket_no_own_listed_players") }}</div>{% endif %}
    </div>
</div>

<script type="text/javascript">
jQuery(function($) {
    var $table = $('#myoffers-overview-table');
    $table.on('click', '.myoffers-sort', function(event) {
        event.preventDefault();
        var $link = $(this), column = $link.attr('data-sort-column');
        var direction = $link.attr('data-sort-direction') === 'asc' ? 'desc' : 'asc';
        var rows = $table.find('tbody > tr').get();
        rows.sort(function(a, b) {
            var valueA = $(a).find('td[data-sort-column="' + column + '"]').attr('data-sort-value') || '';
            var valueB = $(b).find('td[data-sort-column="' + column + '"]').attr('data-sort-value') || '';
            var comparison = column === 'fee' ? ((parseFloat(valueA) || 0) - (parseFloat(valueB) || 0)) : valueA.localeCompare(valueB);
            return direction === 'asc' ? comparison : -comparison;
        });
        $.each(rows, function(index, row) { $(row).find('.myoffers-row-number strong').text(index + 1); $table.find('tbody').append(row); });
        $table.find('.myoffers-sort').removeAttr('data-sort-direction').find('i').attr('class', 'icon-resize-vertical');
        $link.attr('data-sort-direction', direction).find('i').attr('class', direction === 'asc' ? 'icon-chevron-up' : 'icon-chevron-down');
    });
});
</script>
