{% import "macros/badges.twig" as badgesmacros %}
{% extends "base.twig" %}

{% block page_title %}
{{ i18n.getMessage("badges_navlabel") }}
{% endblock %}

{% block page_content %}

<table class="table table-striped">
    <thead>
        <tr>
            <th>{{ i18n.getMessage('entity_badge') }}</th>
            <th>{{ i18n.getMessage('entity_badge_description') }}</th>
            <th>{{ i18n.getMessage('entity_badge_event_benchmark') }}</th>
            <th>{{ i18n.getMessage('badge_earned_count') }}</th>
        </tr>
    </thead>
    <tbody>
    {% for badge in badges %}
        <tr>
            <td>
                {% if badge.earned_count > 0 %}{{ badgesmacros.badge(badge.name, badge.level, badge.last_rewarded) }}{% else %}{{ badgesmacros.badge(badge.name, badge.level) }}{% endif %}
            </td>
            <td>
                {% if badge.description|length and i18n.hasMessage(badge.description) %}
                    {{ i18n.getMessage(badge.description) }}
                {% else %}
                    {{ badge.description }}
                {% endif %}
            </td>
            <td>{{ badge.event_benchmark }}</td>
            <td>{% if badge.earned_count > 0 %}{{ badge.earned_count }}{% else %}-{% endif %}</td>
        </tr>
    {% endfor %}
    </tbody>
</table>

{% endblock %}
