{% extends "base.twig" %}

{% block page_title %}
{{ i18n.getMessage("clubpartnerships_title") }}
{% endblock %}

{% block page_content %}

<h3>{{ i18n.getMessage("clubpartnerships_title") }}</h3>
<p>{{ i18n.getMessage("clubpartnerships_intro") }}</p>

{% if partnerships.team is not defined or partnerships.team.id is not defined %}
    <div class="alert alert-info">{{ i18n.getMessage("clubpartnerships_no_team") }}</div>
{% else %}

    <div class="well">
        <strong>{{ partnerships.team.name }}</strong><br>
        <span class="muted">{{ partnerships.team.league_name }} · {{ i18n.getMessage("clubpartnerships_score") }}: {{ partnerships.team.club_score }}</span>
    </div>

    <h4>{{ i18n.getMessage("clubpartnerships_current_title") }}</h4>
    {% if partnerships.active_partnership.id is defined %}
        {% set p = partnerships.active_partnership %}
        <table class="table table-striped table-bordered">
            <thead>
                <tr>
                    <th>{{ i18n.getMessage("clubpartnerships_parent") }}</th>
                    <th>{{ i18n.getMessage("clubpartnerships_partner") }}</th>
                    <th>{{ i18n.getMessage("clubpartnerships_status") }}</th>
                    <th>{{ i18n.getMessage("clubpartnerships_effects") }}</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td>
                        {% if p.parent_logo|length > 0 %}<img src="{{ env.getConfig("context_root") }}/uploads/club/{{ p.parent_logo }}" style="max-width:24px;max-height:24px;">{% endif %}
                        <a href="{{ env.getInternalUrl("team", "id=" ~ p.parent_team_id) }}">{{ p.parent_name }}</a><br>
                        <small class="muted">{{ p.parent_league_name }} · {{ p.parent_score }} · {{ p.parent_manager_name|default(i18n.getMessage("clubpartnerships_cpu")) }}</small>
                    </td>
                    <td>
                        {% if p.partner_logo|length > 0 %}<img src="{{ env.getConfig("context_root") }}/uploads/club/{{ p.partner_logo }}" style="max-width:24px;max-height:24px;">{% endif %}
                        <a href="{{ env.getInternalUrl("team", "id=" ~ p.partner_team_id) }}">{{ p.partner_name }}</a><br>
                        <small class="muted">{{ p.partner_league_name }} · {{ p.partner_score }} · {{ p.partner_manager_name|default(i18n.getMessage("clubpartnerships_cpu")) }}</small>
                    </td>
                    <td>
                        <span class="label {% if p.status == 'active' %}label-success{% elseif p.status == 'suspended' %}label-warning{% elseif p.status == 'pending' %}label-info{% else %}label-default{% endif %}">{{ i18n.getMessage("clubpartnerships_status_" ~ p.status) }}</span>
                        {% if p.suspended_reason|length > 0 %}<br><small class="muted">{{ p.suspended_reason }}</small>{% endif %}
                        {% if p.status != 'pending' %}
                            <hr style="margin:8px 0;">
                            <strong>{{ i18n.getMessage("clubpartnerships_duration") }}</strong><br>
                            <small>{{ i18n.getMessage("clubpartnerships_duration_progress", p.elapsed_matches, p.minimum_matches) }}</small><br>
                            {% if p.remaining_matches > 0 %}
                                <small class="text-warning">{{ i18n.getMessage("clubpartnerships_duration_remaining", p.remaining_matches) }}</small>
                            {% else %}
                                <small class="text-success">{{ i18n.getMessage("clubpartnerships_duration_complete") }}</small>
                            {% endif %}
                        {% endif %}
                    </td>
                    <td>{{ i18n.getMessage("clubpartnerships_effects_text")|replace({'{0}': p.development_bonus_percent}) }}</td>
                    <td>
                        {% if p.termination_fee_preview > 0 %}
                            <div class="alert alert-warning" style="padding:6px 8px; margin-bottom:8px;">{{ i18n.getMessage("clubpartnerships_termination_warning", p.termination_fee_preview) }}</div>
                        {% endif %}
                        <a class="btn btn-small btn-danger" href="{{ env.getInternalActionUrl("stop-club-partnership", "id=" ~ p.id, "clubpartnerships") }}" onclick="return confirm('{{ i18n.getMessage("clubpartnerships_stop_confirm") }}');"><i class="icon-remove"></i> {{ i18n.getMessage("clubpartnerships_stop") }}</a>
                    </td>
                </tr>
            </tbody>
        </table>
    {% else %}
        <div class="alert alert-info">{{ i18n.getMessage("clubpartnerships_no_current") }}</div>
    {% endif %}


    <h4>{{ i18n.getMessage("clubpartnerships_first_option_title") }}</h4>
    <p class="muted">{{ i18n.getMessage("clubpartnerships_first_option_intro") }}</p>
    {% if partnerships.first_options|length > 0 %}
        <table class="table table-striped table-condensed">
            <thead>
                <tr>
                    <th>{{ i18n.getMessage("clubpartnerships_first_option_player") }}</th>
                    <th>{{ i18n.getMessage("clubpartnerships_first_option_source") }}</th>
                    <th>{{ i18n.getMessage("clubpartnerships_first_option_expires") }}</th>
                    <th>{{ i18n.getMessage("clubpartnerships_status") }}</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
            {% for o in partnerships.first_options %}
                <tr>
                    <td>
                        {% if o.player_id > 0 %}
                            <a href="{{ env.getInternalUrl("player", "id=" ~ o.player_id) }}">{{ o.player_name }}</a>
                        {% else %}
                            {{ o.player_name }}
                        {% endif %}
                        <br><small class="muted">{{ o.parent_name }} / {{ o.partner_name }}</small>
                    </td>
                    <td>{{ i18n.getMessage("clubpartnerships_first_option_source_" ~ o.source) }}</td>
                    <td>{{ o.expires_label }}</td>
                    <td><span class="label {% if o.status == 'open' %}label-info{% elseif o.status == 'used' %}label-success{% elseif o.status == 'declined' %}label-warning{% else %}label-default{% endif %}">{{ i18n.getMessage("clubpartnerships_first_option_status_" ~ o.status) }}</span></td>
                    <td style="white-space:nowrap;">
                        {% if o.status == 'open' and o.is_parent_team == '1' %}
                            {% if o.source == 'professional_transfer' and o.player_id > 0 %}
                                <a class="btn btn-mini btn-primary" href="{{ env.getInternalUrl("transfer-bid", "id=" ~ o.player_id) }}"><i class="icon-hand-up"></i> {{ i18n.getMessage("clubpartnerships_first_option_bid") }}</a>
                            {% elseif o.source == 'youth_transfer' and o.youth_player_id > 0 %}
                                <a class="btn btn-mini btn-primary" href="{{ env.getInternalUrl("youthplayer-buy", "id=" ~ o.youth_player_id) }}"><i class="icon-shopping-cart"></i> {{ i18n.getMessage("clubpartnerships_first_option_buy_youth") }}</a>
                            {% elseif o.player_id > 0 %}
                                <a class="btn btn-mini btn-primary" href="{{ env.getInternalUrl("player", "id=" ~ o.player_id) }}"><i class="icon-user"></i> {{ i18n.getMessage("clubpartnerships_first_option_player_profile") }}</a>
                            {% endif %}
                            <a class="btn btn-mini" href="{{ env.getInternalActionUrl("decline-club-partnership-first-option", "id=" ~ o.id, "clubpartnerships") }}" onclick="return confirm('{{ i18n.getMessage("clubpartnerships_first_option_decline_confirm") }}');"><i class="icon-remove"></i> {{ i18n.getMessage("clubpartnerships_first_option_decline") }}</a>
                        {% elseif o.status == 'open' %}
                            <small class="muted">{{ i18n.getMessage("clubpartnerships_first_option_reserved_for_parent") }}</small>
                        {% endif %}
                    </td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    {% else %}
        <p class="muted">{{ i18n.getMessage("clubpartnerships_first_option_none") }}</p>
    {% endif %}

    <div class="row-fluid">
        <div class="span6">
            <h4>{{ i18n.getMessage("clubpartnerships_incoming_title") }}</h4>
            {% if partnerships.incoming_requests|length > 0 %}
                <table class="table table-striped table-condensed">
                    <thead><tr><th>{{ i18n.getMessage("clubpartnerships_parent") }}</th><th>{{ i18n.getMessage("clubpartnerships_partner") }}</th><th></th></tr></thead>
                    <tbody>
                    {% for p in partnerships.incoming_requests %}
                        <tr>
                            <td>{{ p.parent_name }}<br><small class="muted">{{ p.parent_manager_name|default(i18n.getMessage("clubpartnerships_cpu")) }}</small></td>
                            <td>{{ p.partner_name }}<br><small class="muted">{{ p.partner_manager_name|default(i18n.getMessage("clubpartnerships_cpu")) }}</small></td>
                            <td style="white-space:nowrap;">
                                <a class="btn btn-mini btn-success" href="{{ env.getInternalActionUrl("accept-club-partnership-request", "id=" ~ p.id, "clubpartnerships") }}"><i class="icon-ok"></i> {{ i18n.getMessage("clubpartnerships_accept") }}</a>
                                <a class="btn btn-mini" href="{{ env.getInternalActionUrl("reject-club-partnership-request", "id=" ~ p.id, "clubpartnerships") }}"><i class="icon-remove"></i> {{ i18n.getMessage("clubpartnerships_reject") }}</a>
                            </td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            {% else %}
                <p class="muted">{{ i18n.getMessage("clubpartnerships_no_incoming") }}</p>
            {% endif %}
        </div>
        <div class="span6">
            <h4>{{ i18n.getMessage("clubpartnerships_outgoing_title") }}</h4>
            {% if partnerships.outgoing_requests|length > 0 %}
                <table class="table table-striped table-condensed">
                    <thead><tr><th>{{ i18n.getMessage("clubpartnerships_parent") }}</th><th>{{ i18n.getMessage("clubpartnerships_partner") }}</th><th>{{ i18n.getMessage("clubpartnerships_status") }}</th></tr></thead>
                    <tbody>
                    {% for p in partnerships.outgoing_requests %}
                        <tr>
                            <td>{{ p.parent_name }}</td>
                            <td>{{ p.partner_name }}</td>
                            <td>{{ i18n.getMessage("clubpartnerships_status_" ~ p.status) }}</td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            {% else %}
                <p class="muted">{{ i18n.getMessage("clubpartnerships_no_outgoing") }}</p>
            {% endif %}
        </div>
    </div>

    {% if not partnerships.has_open_partnership %}
        <div class="row-fluid">
            <div class="span6">
                <h4>{{ i18n.getMessage("clubpartnerships_candidates_parent_title") }}</h4>
                {% if partnerships.candidate_parents|length > 0 %}
                    <table class="table table-striped table-condensed">
                        <thead><tr><th>{{ i18n.getMessage("entity_club") }}</th><th>{{ i18n.getMessage("clubpartnerships_score") }}</th><th></th></tr></thead>
                        <tbody>
                        {% for c in partnerships.candidate_parents %}
                            <tr>
                                <td>{% if c.bild|length > 0 %}<img src="{{ env.getConfig("context_root") }}/uploads/club/{{ c.bild }}" style="max-width:24px;max-height:24px;">{% endif %} {{ c.name }}<br><small class="muted">{{ c.league_name }} · {{ c.manager_name|default(i18n.getMessage("clubpartnerships_cpu")) }}</small></td>
                                <td>{{ c.club_score }}</td>
                                <td><a class="btn btn-mini btn-primary" href="{{ env.getInternalActionUrl("create-club-partnership-request", "parentTeamId=" ~ c.id ~ "&partnerTeamId=" ~ partnerships.team.id, "clubpartnerships") }}"><i class="icon-envelope"></i> {{ i18n.getMessage("clubpartnerships_create_as_partner") }}</a></td>
                            </tr>
                        {% endfor %}
                        </tbody>
                    </table>
                {% else %}
                    <p class="muted">{{ i18n.getMessage("clubpartnerships_no_candidates") }}</p>
                {% endif %}
            </div>
            <div class="span6">
                <h4>{{ i18n.getMessage("clubpartnerships_candidates_partner_title") }}</h4>
                {% if partnerships.candidate_partners|length > 0 %}
                    <table class="table table-striped table-condensed">
                        <thead><tr><th>{{ i18n.getMessage("entity_club") }}</th><th>{{ i18n.getMessage("clubpartnerships_score") }}</th><th></th></tr></thead>
                        <tbody>
                        {% for c in partnerships.candidate_partners %}
                            <tr>
                                <td>{% if c.bild|length > 0 %}<img src="{{ env.getConfig("context_root") }}/uploads/club/{{ c.bild }}" style="max-width:24px;max-height:24px;">{% endif %} {{ c.name }}<br><small class="muted">{{ c.league_name }} · {{ c.manager_name|default(i18n.getMessage("clubpartnerships_cpu")) }}</small></td>
                                <td>{{ c.club_score }}</td>
                                <td><a class="btn btn-mini btn-primary" href="{{ env.getInternalActionUrl("create-club-partnership-request", "parentTeamId=" ~ partnerships.team.id ~ "&partnerTeamId=" ~ c.id, "clubpartnerships") }}"><i class="icon-envelope"></i> {{ i18n.getMessage("clubpartnerships_create_as_parent") }}</a></td>
                            </tr>
                        {% endfor %}
                        </tbody>
                    </table>
                {% else %}
                    <p class="muted">{{ i18n.getMessage("clubpartnerships_no_candidates") }}</p>
                {% endif %}
            </div>
        </div>
    {% endif %}

    <h4>{{ i18n.getMessage("clubpartnerships_recent_log") }}</h4>
    {% if partnerships.recent_logs|length > 0 %}
        <table class="table table-striped table-condensed">
            <thead><tr><th>Datum</th><th>{{ i18n.getMessage("clubpartnerships_status") }}</th><th>{{ i18n.getMessage("entity_club") }}</th></tr></thead>
            <tbody>
            {% for log in partnerships.recent_logs %}
                <tr>
                    <td>{{ env.getFormattedDate(log.created_date) }}</td>
                    <td>{{ log.message }}</td>
                    <td>{{ log.parent_name }} / {{ log.partner_name }}</td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    {% else %}
        <p class="muted">{{ i18n.getMessage("clubpartnerships_no_log") }}</p>
    {% endif %}
{% endif %}

{% endblock %}
