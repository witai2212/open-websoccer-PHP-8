{% extends "base.twig" %}

{% block page_title %}
{{ i18n.getMessage("individual-training_navlabel") }}
{% endblock %}

{% block page_content %}

<h3>{{ i18n.getMessage("individual_training_title") }}</h3>
<p>{{ i18n.getMessage("individual_training_intro") }}</p>
<p class="muted"><i class="icon-ok"></i> {{ i18n.getMessage("individual_training_autosave_hint") }}</p>

{% if not human_team %}
    <div class="alert alert-warning">{{ i18n.getMessage("individual_training_only_human") }}</div>
{% else %}

<div class="row-fluid">
    <div class="span4">
        <div class="well">
            <strong>{{ i18n.getMessage("training_units_count") }}</strong><br>
            {{ trainingUnits }}
        </div>
    </div>
    <div class="span4">
        <div class="well">
            <strong>{{ i18n.getMessage("training_current_trainer") }}</strong><br>
            {% if currentTrainer.id is defined %}
                {{ currentTrainer.name }}
            {% else %}
                {{ i18n.getMessage("individual_training_no_trainer") }}
            {% endif %}
        </div>
    </div>
    <div class="span4">
        <div class="well">
            <strong>{{ i18n.getMessage("individual_training_progress_hint_title") }}</strong><br>
            {{ i18n.getMessage("individual_training_progress_hint") }}
        </div>
    </div>
</div>

{% if trainingUnits < 1 %}
    <div class="alert alert-warning">
        <i class="icon-info-sign"></i>
        {{ i18n.getMessage("individual_training_no_units_warning") }}
    </div>
{% endif %}

<table class="table table-striped table-condensed">
    <thead>
        <tr>
            <th>{{ i18n.getMessage("entity_player") }}</th>
            <th>{{ i18n.getMessage("individual_training_recommendation") }}</th>
            <th>{{ i18n.getMessage("individual_training_current") }}</th>
            <th>{{ i18n.getMessage("individual_training_selected") }}</th>
            <th>{{ i18n.getMessage("individual_training_progress") }}</th>
        </tr>
    </thead>
    <tbody>
    {% for player in players %}
        {% set active = player.active_training %}
        <tr>
            <td>
                <strong><a href="{{ env.getInternalUrl('player', 'id=' ~ player.id) }}">{{ player.name }}</a></strong><br>
                <small>{{ player.position_main }}{% if player.age > 0 %}, {{ player.age }} {{ i18n.getMessage("individual_training_age_years") }}{% endif %}</small>
            </td>
            <td>
                {% for attribute in player.weak_attributes %}
                    <span class="label">{{ i18n.getMessage(attributeLabels[attribute]) }}: {{ player.current_values[attribute] }}</span>
                {% endfor %}
            </td>
            <td>
                {% if active.id is defined %}
                    {{ i18n.getMessage(attributeLabels[active.attribute_key]) }}: {{ player.current_values[active.attribute_key] }}
                {% else %}
                    -
                {% endif %}
            </td>
            <td>
                <form method="post" class="form-inline individual-training-autosave-form" style="margin: 0;">
                    <select name="attribute" class="input-medium individual-training-autosave-select">
                        <option value="">{{ i18n.getMessage("individual_training_none") }}</option>
                        {% for attribute in player.available_attributes %}
                            <option value="{{ attribute }}"{% if active.id is defined and active.attribute_key == attribute %} selected{% endif %}>{{ i18n.getMessage(attributeLabels[attribute]) }}</option>
                        {% endfor %}
                    </select>
                    <input type="hidden" name="player_id" value="{{ player.id }}" />
                    <input type="hidden" name="page" value="individual-training" />
                    <input type="hidden" name="action" value="save-individual-training" />
                    <button type="submit" class="btn btn-mini btn-primary individual-training-manual-save"><i class="icon-ok icon-white"></i> {{ i18n.getMessage("button_save") }}</button>
                    <span class="muted individual-training-autosave-status" data-saving='{{ i18n.getMessage("individual_training_autosave_saving") }}'></span>
                </form>
            </td>
            <td>
                {% if active.id is defined %}
                    <div class="progress" style="margin-bottom: 4px; min-width: 120px;">
                        <div class="bar" style="width: {{ active.progress_percent }}%;"></div>
                    </div>
                    <small>
                        {{ active.progress_matches }} {{ i18n.getMessage("individual_training_units_done") }},
                        {{ i18n.getMessage("individual_training_remaining_approx") }} {{ active.remaining_matches }}
                    </small>
                {% else %}
                    <span class="muted">{{ i18n.getMessage("individual_training_not_active") }}</span>
                {% endif %}
            </td>
        </tr>
    {% endfor %}
    </tbody>
</table>

{% if completedTrainings|length > 0 %}
    <h4>{{ i18n.getMessage("individual_training_completed_title") }}</h4>
    <table class="table table-striped table-condensed">
        <thead>
            <tr>
                <th>{{ i18n.getMessage("individual_training_completed_date") }}</th>
                <th>{{ i18n.getMessage("entity_player") }}</th>
                <th>{{ i18n.getMessage("individual_training_selected") }}</th>
                <th>{{ i18n.getMessage("individual_training_result") }}</th>
                <th>{{ i18n.getMessage("individual_training_units_done") }}</th>
            </tr>
        </thead>
        <tbody>
        {% for item in completedTrainings %}
            <tr>
                <td>{{ env.getFormattedDatetime(item.completed_date) }}</td>
                <td><a href="{{ env.getInternalUrl('player', 'id=' ~ item.player_id) }}">{{ item.name }}</a></td>
                <td>{{ i18n.getMessage(attributeLabels[item.attribute_key]) }}</td>
                <td>{{ item.old_value }} → {{ item.new_value }}</td>
                <td>{{ item.progress_matches }}</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
{% endif %}

{% endif %}

<script type="text/javascript">
(function() {
    var forms = document.getElementsByClassName ? document.getElementsByClassName('individual-training-autosave-form') : [];
    for (var i = 0; i < forms.length; i++) {
        var form = forms[i];
        var buttons = form.getElementsByTagName('button');
        for (var b = 0; b < buttons.length; b++) {
            if ((' ' + buttons[b].className + ' ').indexOf(' individual-training-manual-save ') !== -1) {
                buttons[b].style.display = 'none';
            }
        }

        var selects = form.getElementsByTagName('select');
        if (selects.length < 1) {
            continue;
        }

        selects[0].onchange = function() {
            var statusItems = this.form.getElementsByTagName('span');
            for (var s = 0; s < statusItems.length; s++) {
                if ((' ' + statusItems[s].className + ' ').indexOf(' individual-training-autosave-status ') !== -1) {
                    statusItems[s].innerHTML = statusItems[s].getAttribute('data-saving');
                }
            }
            this.form.submit();
        };
    }
})();
</script>

{% endblock %}
