{% extends "base.twig" %}

{% block page_title %}
{{ i18n.getMessage("managercareer_page_title") }}
{% endblock %}

{% block page_content %}

<h3>{{ i18n.getMessage("managercareer_page_title") }}</h3>
<p>{{ i18n.getMessage("managercareer_page_intro") }}</p>

{% if career.managercareer_extended_error is defined %}
    <div class="alert alert-warning">
        <strong>{{ i18n.getMessage("alert_warning_title") }}</strong><br>
        {{ i18n.getMessage("managercareer_install_hint") }}<br>
        <small>{{ career.managercareer_extended_error }}</small>
    </div>
{% endif %}

<ul class="nav nav-tabs" id="managerCareerTab">
    <li class="active"><a href="#mc-overview" data-toggle="tab">{{ i18n.getMessage("managercareer_subtab_overview") }}</a></li>
    <li><a href="#mc-history" data-toggle="tab">{{ i18n.getMessage("managercareer_subtab_history") }}</a></li>
    <li><a href="#mc-applications" data-toggle="tab">{{ i18n.getMessage("managercareer_subtab_applications") }}</a></li>
    <li><a href="#mc-offers" data-toggle="tab">{{ i18n.getMessage("managercareer_subtab_offers") }}</a></li>
    <li><a href="#mc-objectives" data-toggle="tab">{{ i18n.getMessage("managercareer_subtab_objectives") }}</a></li>
    <li><a href="#mc-reputation" data-toggle="tab">{{ i18n.getMessage("managercareer_subtab_reputation") }}</a></li>
    <li><a href="#mc-awards" data-toggle="tab">{{ i18n.getMessage("managercareer_subtab_awards") }}</a></li>
</ul>

<div class="tab-content">
    <div class="tab-pane active" id="mc-overview">
        <div class="row-fluid">
            <div class="span3">
                <div class="well">
                    <strong>{{ i18n.getMessage("managercareer_reputation") }}</strong><br>
                    <span style="font-size: 28px; line-height: 36px;">{{ career.manager_score }}</span>
                    <p class="muted">{{ i18n.getMessage("managercareer_reputation_help") }}</p>
                </div>
            </div>
            <div class="span3">
                <div class="well">
                    <strong>{{ i18n.getMessage("managercareer_stat_matches") }}</strong><br>
                    <span style="font-size: 28px; line-height: 36px;">{{ career.manager_statistics.matches }}</span>
                    <p class="muted">{{ career.manager_statistics.wins }} / {{ career.manager_statistics.draws }} / {{ career.manager_statistics.losses }}</p>
                </div>
            </div>
            <div class="span3">
                <div class="well">
                    <strong>{{ i18n.getMessage("managercareer_stat_winrate") }}</strong><br>
                    <span style="font-size: 28px; line-height: 36px;">{{ career.manager_statistics.win_rate }}%</span>
                    <p class="muted">{{ i18n.getMessage("managercareer_stat_titles") }}: {{ career.manager_statistics.titles }}</p>
                </div>
            </div>
            <div class="span3">
                <div class="well">
                    <strong>{{ i18n.getMessage("managercareer_board_average") }}</strong><br>
                    <span style="font-size: 28px; line-height: 36px;">{% if career.avg_board_satisfaction > 0 %}{{ career.avg_board_satisfaction }}%{% else %}-{% endif %}</span>
                    <p class="muted">{{ i18n.getMessage("managercareer_sack_risk_title") }}</p>
                </div>
            </div>
        </div>

        <div class="row-fluid">
            <div class="span6">
                <h4>{{ i18n.getMessage("managercareer_current_teams") }}</h4>
                {% if career.teams|length > 0 %}
                    <table class="table table-striped table-condensed">
                        <thead>
                            <tr>
                                <th>{{ i18n.getMessage("entity_club_name") }}</th>
                                <th>{{ i18n.getMessage("managercareer_board_satisfaction") }}</th>
                                <th>{{ i18n.getMessage("managercareer_sack_risk") }}</th>
                            </tr>
                        </thead>
                        <tbody>
                        {% for team in career.teams %}
                            {% set risk = career.sack_risks_by_team[team.id]|default(null) %}
                            <tr>
                                <td><a href="{{ env.getInternalUrl("team", "id=" ~ team.id) }}">{{ team.name }}</a></td>
                                <td>{{ team.board_satisfaction }}%</td>
                                <td>{% if risk %}<span class="label {{ risk.risk_class }}">{{ risk.risk_label }}</span>{% else %}-{% endif %}</td>
                            </tr>
                        {% endfor %}
                        </tbody>
                    </table>
                {% else %}
                    <div class="alert alert-info">{{ i18n.getMessage("managercareer_no_current_team") }}</div>
                {% endif %}
            </div>
            <div class="span6">
                <h4>{{ i18n.getMessage("managercareer_contracts_title") }}</h4>
                {% if career.manager_contracts|length > 0 %}
                    <table class="table table-striped table-condensed">
                        <thead>
                            <tr>
                                <th>{{ i18n.getMessage("entity_club_name") }}</th>
                                <th>{{ i18n.getMessage("managercareer_contract_until") }}</th>
                                <th>{{ i18n.getMessage("managercareer_status") }}</th>
                            </tr>
                        </thead>
                        <tbody>
                        {% for contract in career.manager_contracts %}
                            <tr>
                                <td>{{ contract.team_name }}</td>
                                <td>{% if contract.contract_until_date > 0 %}{{ env.getFormattedDate(contract.contract_until_date) }}{% else %}-{% endif %}</td>
                                <td>{{ i18n.getMessage("managercareer_contract_status_" ~ contract.status) }}</td>
                            </tr>
                        {% endfor %}
                        </tbody>
                    </table>
                {% else %}
                    <p class="muted">{{ i18n.getMessage("managercareer_no_contracts") }}</p>
                {% endif %}
            </div>
        </div>
    </div>

    <div class="tab-pane" id="mc-history">
        <h4>{{ i18n.getMessage("managercareer_history_title") }}</h4>
        {% if career.history|length > 0 %}
            <table class="table table-striped table-condensed">
                <thead>
                    <tr>
                        <th>{{ i18n.getMessage("managercareer_date") }}</th>
                        <th>{{ i18n.getMessage("managercareer_old_club") }}</th>
                        <th>{{ i18n.getMessage("managercareer_new_club") }}</th>
                        <th>{{ i18n.getMessage("managercareer_origin") }}</th>
                        <th>{{ i18n.getMessage("managercareer_bonus") }}</th>
                    </tr>
                </thead>
                <tbody>
                {% for item in career.history %}
                    <tr>
                        <td>{{ env.getFormattedDate(item.change_date) }}</td>
                        <td>{% if item.old_team_id > 0 %}<a href="{{ env.getInternalUrl("team", "id=" ~ item.old_team_id) }}">{{ item.old_team_name }}</a>{% else %}-{% endif %}</td>
                        <td>{% if item.new_team_id > 0 %}<a href="{{ env.getInternalUrl("team", "id=" ~ item.new_team_id) }}">{{ item.new_team_name }}</a>{% else %}-{% endif %}</td>
                        <td>{{ i18n.getMessage("managercareer_origin_" ~ item.origin) }}</td>
                        <td>{% if item.highscore_bonus > 0 %}+{{ item.highscore_bonus }}{% else %}-{% endif %}</td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        {% else %}
            <p class="muted">{{ i18n.getMessage("managercareer_no_history") }}</p>
        {% endif %}
    </div>

    <div class="tab-pane" id="mc-applications">
        <h4>{{ i18n.getMessage("managercareer_applications_title") }}</h4>
        <p class="muted">{{ i18n.getMessage("managercareer_applications_help") }}</p>

        {% if not career.applications_enabled %}
            <div class="alert alert-info">{{ i18n.getMessage("managercareer_applications_disabled") }}</div>
        {% else %}
            <div class="alert alert-info">
                {{ i18n.getMessage("managercareer_applications_limit_hint") }} {{ career.application_open_count }} / {{ career.application_limit }}
            </div>

            {% if career.applications|length > 0 %}
                <table class="table table-striped table-condensed">
                    <thead>
                        <tr>
                            <th>{{ i18n.getMessage("entity_club_name") }}</th>
                            <th>{{ i18n.getMessage("entity_club_liga_id") }}</th>
                            <th>{{ i18n.getMessage("managercareer_application_chance") }}</th>
                            <th>{{ i18n.getMessage("managercareer_decision_date") }}</th>
                            <th>{{ i18n.getMessage("managercareer_status") }}</th>
                            <th>&nbsp;</th>
                        </tr>
                    </thead>
                    <tbody>
                    {% for application in career.applications %}
                        <tr>
                            <td><a href="{{ env.getInternalUrl("team", "id=" ~ application.target_team_id) }}">{{ application.team_name }}</a></td>
                            <td><a href="{{ env.getInternalUrl("league", "id=" ~ application.league_id) }}">{{ application.league_name }}</a></td>
                            <td>{{ application.acceptance_chance }}%</td>
                            <td>{% if application.status == 'open' %}{{ env.getFormattedDate(application.decision_date) }}{% else %}{{ env.getFormattedDate(application.answered_date) }}{% endif %}</td>
                            <td><span class="label">{{ i18n.getMessage("managercareer_application_status_" ~ application.status) }}</span></td>
                            <td>
                                {% if application.status == 'open' %}
                                    <a href="{{ env.getInternalActionUrl("withdraw-manager-application", "applicationId=" ~ application.id, "managercareer") }}" class="btn btn-small" onclick="return confirm('{{ i18n.getMessage("managercareer_confirm_withdraw_application") }}');"><i class="icon-remove"></i> {{ i18n.getMessage("managercareer_button_withdraw") }}</a>
                                {% elseif application.status == 'accepted' and application.offer_id > 0 %}
                                    <a href="#mc-offers" class="btn btn-small" data-toggle="tab">{{ i18n.getMessage("managercareer_open_offer") }}</a>
                                {% else %}
                                    -
                                {% endif %}
                            </td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            {% else %}
                <p class="muted">{{ i18n.getMessage("managercareer_no_applications") }}</p>
            {% endif %}

            <h4>{{ i18n.getMessage("managercareer_application_candidates_title") }}</h4>
            <form method="get" action="{{ env.getConfig("context_root") }}/#mc-applications" class="form-search">
                <input type="hidden" name="page" value="managercareer" />
                <input type="text" name="applicationSearch" value="{{ career.application_search }}" class="input-xlarge search-query" placeholder="{{ i18n.getMessage("managercareer_application_search_placeholder") }}" />
                <button type="submit" class="btn"><i class="icon-search"></i> {{ i18n.getMessage("button_search") }}</button>
                {% if career.application_search|length > 0 %}
                    <a href="{{ env.getInternalUrl("managercareer") }}#mc-applications" class="btn">{{ i18n.getMessage("button_reset") }}</a>
                {% endif %}
            </form>
            {% if career.application_candidates|length > 0 %}
                <table class="table table-striped table-condensed">
                    <thead>
                        <tr>
                            <th>{{ i18n.getMessage("entity_club_name") }}</th>
                            <th>{{ i18n.getMessage("entity_club_liga_id") }}</th>
                            <th>{{ i18n.getMessage("managercareer_club_score") }}</th>
                            <th>{{ i18n.getMessage("managercareer_required_score") }}</th>
                            <th>{{ i18n.getMessage("managercareer_application_chance") }}</th>
                            <th>&nbsp;</th>
                        </tr>
                    </thead>
                    <tbody>
                    {% for club in career.application_candidates %}
                        <tr>
                            <td><a href="{{ env.getInternalUrl("team", "id=" ~ club.team_id) }}">{{ club.team_name }}</a></td>
                            <td><a href="{{ env.getInternalUrl("league", "id=" ~ club.league_id) }}">{{ club.league_name }}</a></td>
                            <td>{{ club.club_score }}</td>
                            <td><span class="label {{ club.career_status_class }}">{{ club.required_score }}</span></td>
                            <td>{{ club.acceptance_chance }}%</td>
                            <td>
                                {% if club.already_applied %}
                                    <span class="label">{{ i18n.getMessage("managercareer_already_applied") }}</span>
                                {% elseif career.application_open_count >= career.application_limit %}
                                    <span class="muted">{{ i18n.getMessage("managercareer_application_limit_reached") }}</span>
                                {% else %}
                                    <a href="{{ env.getInternalActionUrl("apply-manager-job", "teamId=" ~ club.team_id, "managercareer") }}" class="btn btn-small btn-primary" onclick="return confirm('{{ i18n.getMessage("managercareer_confirm_apply") }}');"><i class="icon-envelope"></i> {{ i18n.getMessage("managercareer_button_apply") }}</a>
                                {% endif %}
                            </td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            {% else %}
                <p class="muted">{{ i18n.getMessage("managercareer_no_application_candidates") }}</p>
            {% endif %}
        {% endif %}
    </div>

    <div class="tab-pane" id="mc-offers">
        <h4>{{ i18n.getMessage("managercareer_offers_title") }}</h4>
        {% if career.job_offers_enabled %}
            {% if career.open_offers|length > 0 %}
                <table class="table table-striped table-condensed">
                    <thead>
                        <tr>
                            <th>{{ i18n.getMessage("entity_club_name") }}</th>
                            <th>{{ i18n.getMessage("entity_club_liga_id") }}</th>
                            <th>{{ i18n.getMessage("managercareer_club_score") }}</th>
                            <th>{{ i18n.getMessage("managercareer_offer_until") }}</th>
                            <th>&nbsp;</th>
                        </tr>
                    </thead>
                    <tbody>
                    {% for offer in career.open_offers %}
                        <tr>
                            <td><a href="{{ env.getInternalUrl("team", "id=" ~ offer.team_id) }}">{{ offer.team_name }}</a></td>
                            <td><a href="{{ env.getInternalUrl("league", "id=" ~ offer.league_id) }}">{{ offer.league_name }}</a></td>
                            <td>{{ offer.club_score }}</td>
                            <td>{{ env.getFormattedDate(offer.expires_date) }}</td>
                            <td>
                                <a href="{{ env.getInternalActionUrl("accept-manager-job", "offerId=" ~ offer.offer_id, "managercareer") }}" class="btn btn-small btn-success" onclick="return confirm('{{ i18n.getMessage("managercareer_confirm_accept") }}');"><i class="icon-ok"></i> {{ i18n.getMessage("managercareer_button_accept") }}</a>
                                <a href="{{ env.getInternalActionUrl("decline-manager-job", "offerId=" ~ offer.offer_id, "managercareer") }}" class="btn btn-small"><i class="icon-remove"></i> {{ i18n.getMessage("managercareer_button_decline") }}</a>
                            </td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            {% else %}
                <p class="muted">{{ i18n.getMessage("managercareer_no_open_offers") }}</p>
            {% endif %}
        {% else %}
            <p class="muted">{{ i18n.getMessage("managercareer_offers_disabled") }}</p>
        {% endif %}
    </div>

    <div class="tab-pane" id="mc-objectives">
        <h4>{{ i18n.getMessage("managercareer_objectives_title") }}</h4>
        <p class="muted">{{ i18n.getMessage("managercareer_objectives_help") }}</p>
        {% if career.mission_snapshot|length > 0 %}
            <table class="table table-striped table-condensed">
                <thead>
                    <tr>
                        <th>{{ i18n.getMessage("entity_club_name") }}</th>
                        <th>{{ i18n.getMessage("manager_mission_season") }}</th>
                        <th>{{ i18n.getMessage("managercareer_objective_type") }}</th>
                        <th>{{ i18n.getMessage("managercareer_status") }}</th>
                        <th>{{ i18n.getMessage("manager_mission_current") }}</th>
                    </tr>
                </thead>
                <tbody>
                {% for mission in career.mission_snapshot %}
                    <tr>
                        <td>{{ mission.team_name }}</td>
                        <td>{{ mission.season_name }}</td>
                        <td>{{ i18n.getMessage("manager_mission_type_" ~ mission.mission_type) }}</td>
                        <td>{{ i18n.getMessage("manager_mission_status_" ~ mission.status) }}</td>
                        <td>{{ mission.progress_value }} / {{ mission.target_value }}</td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        {% else %}
            <p class="muted">{{ i18n.getMessage("managercareer_no_objectives") }}</p>
        {% endif %}
        <p><a href="{{ env.getInternalUrl("manager-missions") }}" class="btn"><i class="icon-tasks"></i> {{ i18n.getMessage("managercareer_open_objectives_page") }}</a></p>
    </div>

    <div class="tab-pane" id="mc-reputation">
        <h4>{{ i18n.getMessage("managercareer_country_reputation_title") }}</h4>
        <p class="muted">{{ i18n.getMessage("managercareer_country_reputation_help") }}</p>
        {% if career.country_reputation|length > 0 %}
            <table class="table table-striped table-condensed">
                <thead>
                    <tr>
                        <th>{{ i18n.getMessage("entity_country") }}</th>
                        <th>{{ i18n.getMessage("managercareer_reputation") }}</th>
                        <th>{{ i18n.getMessage("managercareer_last_change") }}</th>
                    </tr>
                </thead>
                <tbody>
                {% for country in career.country_reputation %}
                    <tr>
                        <td>{{ country.country }}</td>
                        <td>{{ country.reputation }}</td>
                        <td>{% if country.last_change > 0 %}+{{ country.last_change }}{% else %}{{ country.last_change }}{% endif %}</td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        {% else %}
            <p class="muted">{{ i18n.getMessage("managercareer_no_country_reputation") }}</p>
        {% endif %}
    </div>

    <div class="tab-pane" id="mc-awards">
        <h4>{{ i18n.getMessage("managercareer_awards_title") }}</h4>
        {% if career.manager_awards|length > 0 %}
            <table class="table table-striped table-condensed">
                <thead>
                    <tr>
                        <th>{{ i18n.getMessage("managercareer_date") }}</th>
                        <th>{{ i18n.getMessage("managercareer_award") }}</th>
                        <th>{{ i18n.getMessage("entity_club_name") }}</th>
                        <th>{{ i18n.getMessage("managercareer_bonus") }}</th>
                    </tr>
                </thead>
                <tbody>
                {% for award in career.manager_awards %}
                    <tr>
                        <td>{{ env.getFormattedDate(award.created_date) }}</td>
                        <td><strong>{{ award.title }}</strong><br><small>{{ award.description }}</small></td>
                        <td>{% if award.team_name|length %}{{ award.team_name }}{% else %}-{% endif %}</td>
                        <td>{{ award.score_value }}</td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        {% else %}
            <p class="muted">{{ i18n.getMessage("managercareer_no_awards") }}</p>
        {% endif %}
    </div>
</div>

{% endblock %}
