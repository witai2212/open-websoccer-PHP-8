{% extends "base.twig" %}

{% block page_title %}
{{ i18n.getMessage("manager_rankings_title") }}
{% endblock %}

{% block page_content %}

<div class="well">
    <h3 style="margin-top:0"><i class="icon-trophy"></i> {{ i18n.getMessage("manager_rankings_title") }}</h3>
    <p>{{ i18n.getMessage("manager_rankings_intro") }}</p>
</div>

{% if managers|length == 0 %}
    {{ i18n.getMessage("no_items") }}
{% else %}
    <table class="table table-striped table-hover">
        <thead>
            <tr>
                <th>{{ i18n.getMessage("highscore_teams_rank") }}</th>
                <th>{{ i18n.getMessage("highscore_teams_manager") }}</th>
                <th>{{ i18n.getMessage("entity_club") }}</th>
                <th>{{ i18n.getMessage("manager_rankings_reputation") }}</th>
                <th>{{ i18n.getMessage("manager_rankings_competence") }}</th>
                <th>{{ i18n.getMessage("highscore_teams_score") }}</th>
                <th>{{ i18n.getMessage("manager_rankings_titles") }}</th>
                <th>{{ i18n.getMessage("manager_rankings_achievements") }}</th>
                <th>{{ i18n.getMessage("manager_rankings_badges") }}</th>
                <th>{{ i18n.getMessage("manager_rankings_awards") }}</th>
            </tr>
        </thead>
        <tbody>
        {% for manager in managers %}
            <tr{% if loop.index <= 3 %} class="success"{% endif %}>
                <td><strong>{{ loop.index }}</strong></td>
                <td><a href="{{ env.getInternalUrl("user", "id=" ~ manager.user_id) }}">{{ manager.manager_name }}</a></td>
                <td>
                    {% if manager.club_id > 0 %}
                        {% if manager.club_bild|length > 0 %}<img src="{{ env.getConfig("context_root") }}/uploads/club/{{ manager.club_bild }}" alt="{{ manager.club_name }}" style="max-width:24px;max-height:24px;margin-right:5px" />{% endif %}
                        <a href="{{ env.getInternalUrl("team", "id=" ~ manager.club_id) }}">{{ manager.club_name }}</a>
                    {% else %}-{% endif %}
                </td>
                <td><strong>{{ manager.reputation|number_format(0, ',', ' ') }}</strong></td>
                <td>{{ manager.manager_competence|default(10) }}/20</td>
                <td>{{ manager.highscore|number_format(0, ',', ' ') }}</td>
                <td>{{ manager.titles|number_format(0, ',', ' ') }}</td>
                <td>{{ manager.achievements|number_format(0, ',', ' ') }}</td>
                <td>{{ manager.badges|number_format(0, ',', ' ') }}</td>
                <td>{{ manager.manager_awards|number_format(0, ',', ' ') }}</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
{% endif %}

{% endblock %}
