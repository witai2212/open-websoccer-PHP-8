{% extends "base.twig" %}

{% block page_title %}
{{ i18n.getMessage("medicalcenter_title") }}
{% endblock %}

{% block page_content %}

<h3>{{ i18n.getMessage("medicalcenter_title") }}</h3>
<p>{{ i18n.getMessage("medicalcenter_intro") }}</p>

{% if not enabled %}
    <div class="alert alert-warning">{{ i18n.getMessage("medicalcenter_disabled") }}</div>
{% elseif not human_team %}
    <div class="alert alert-warning">{{ i18n.getMessage("medicalcenter_only_human") }}</div>
{% else %}

<p>
    <strong>{{ i18n.getMessage("medicalcenter_budget") }}:</strong>
    {{ team.finanz_budget|number_format(0, ',', ' ') }} {{ env.getConfig("game_currency") }}
</p>

<div class="row-fluid">
    <div class="span6">
        <div class="well">
            <h4>{{ i18n.getMessage("medicalcenter_quality_title") }}</h4>
            <dl class="dl-horizontal">
                <dt>{{ i18n.getMessage("medicalcenter_quality_physio") }}</dt>
                <dd>+{{ quality.physio }}%</dd>
                <dt>{{ i18n.getMessage("medicalcenter_quality_facility") }}</dt>
                <dd>{{ quality.facility }}</dd>
                <dt>{{ i18n.getMessage("medicalcenter_quality_total") }}</dt>
                <dd>{{ quality.total }}</dd>
            </dl>
        </div>
    </div>
    <div class="span6">
        <div class="well">
            <h4>{{ i18n.getMessage("medicalcenter_next_match") }}</h4>
            {% if next_match.match_id is defined %}
                <p><em>{{ env.getFormattedDatetime(next_match.match_date) }}</em></p>
                <p><strong>{{ next_match.match_home_name }} - {{ next_match.match_guest_name }}</strong></p>
            {% else %}
                <p>{{ i18n.getMessage("medicalcenter_no_next_match") }}</p>
            {% endif %}
        </div>
    </div>
</div>

<h4>{{ i18n.getMessage("medicalcenter_current_injuries") }}</h4>

{% if injured_players|length == 0 %}
    <p>{{ i18n.getMessage("medicalcenter_no_injuries") }}</p>
{% else %}
    <table class="table table-striped table-bordered">
        <thead>
            <tr>
                <th>{{ i18n.getMessage("medicalcenter_player") }}</th>
                <th>{{ i18n.getMessage("medicalcenter_position") }}</th>
                <th>{{ i18n.getMessage("medicalcenter_injury_matches") }}</th>
                <th>{{ i18n.getMessage("medicalcenter_recovery_estimate") }}</th>
                <th>{{ i18n.getMessage("medicalcenter_risk") }}</th>
                <th>{{ i18n.getMessage("medicalcenter_treatments") }}</th>
                <th>{{ i18n.getMessage("medicalcenter_clear_to_play") }}</th>
            </tr>
        </thead>
        <tbody>
        {% for player in injured_players %}
            <tr>
                <td>
                    <strong><a href="{{ env.getInternalUrl("player", "id=" ~ player.id) }}">{{ player.name }}</a></strong>
                    {% if player.risk_reasons|length > 0 %}<br><small>{{ player.risk_reasons }}</small>{% endif %}
                </td>
                <td>{{ i18n.getMessage("player_position_" ~ player.position) }}</td>
                <td>{{ player.matches_injured }}</td>
                <td>{{ i18n.getMessage("medicalcenter_recovery_estimate_value", player.matches_injured) }}</td>
                <td>
                    <span class="label{% if player.risk_level == 'high' %} label-important{% elseif player.risk_level == 'medium' %} label-warning{% else %} label-success{% endif %}">
                        {{ player.risk }}% - {{ i18n.getMessage("medicalcenter_risk_" ~ player.risk_level) }}
                    </span>
                </td>
                <td>
                    {% for treatment in treatments %}
                        <a class="btn btn-mini{% if treatment.key == 'risky_cure' %} btn-danger{% elseif treatment.key == 'specialist' %} btn-primary{% endif %}"
                           href="{{ env.getInternalActionUrl("apply-medical-treatment", "id=" ~ player.id ~ "&treatment=" ~ treatment.key) }}"
                           title="{{ i18n.getMessage("medicalcenter_treatment_" ~ treatment.key ~ "_desc") }}">
                            {{ i18n.getMessage("medicalcenter_treatment_" ~ treatment.key) }}
                            {% if treatment.cost > 0 %}({{ treatment.cost|number_format(0, ',', ' ') }} {{ env.getConfig("game_currency") }}){% endif %}
                        </a><br>
                    {% endfor %}
                </td>
                <td>
                    {% if player.cleared_to_play %}
                        <span class="label label-warning">{{ i18n.getMessage("medicalcenter_clearance_active") }}</span>
                    {% elseif player.matches_injured == 1 and next_match.match_id is defined %}
                        <a class="btn btn-mini btn-warning" href="{{ env.getInternalActionUrl("clear-player-risk", "id=" ~ player.id) }}" title="{{ i18n.getMessage("medicalcenter_clear_to_play_desc") }}">
                            {{ i18n.getMessage("medicalcenter_clear_to_play_button") }}
                        </a>
                    {% else %}
                        <small>{{ i18n.getMessage("medicalcenter_clear_to_play_desc") }}</small>
                    {% endif %}
                </td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
{% endif %}

<hr>

<h4>{{ i18n.getMessage("medicalcenter_risk_players") }}</h4>

{% if risk_players|length == 0 %}
    <p>{{ i18n.getMessage("medicalcenter_no_risk_players") }}</p>
{% else %}
    <table class="table table-striped">
        <thead>
            <tr>
                <th>{{ i18n.getMessage("medicalcenter_player") }}</th>
                <th>{{ i18n.getMessage("medicalcenter_position") }}</th>
                <th>{{ i18n.getMessage("medicalcenter_age") }}</th>
                <th>{{ i18n.getMessage("entity_player_w_frische") }}</th>
                <th>{{ i18n.getMessage("entity_player_w_kondition") }}</th>
                <th>{{ i18n.getMessage("medicalcenter_risk") }}</th>
            </tr>
        </thead>
        <tbody>
        {% for player in risk_players %}
            <tr>
                <td>
                    <strong><a href="{{ env.getInternalUrl("player", "id=" ~ player.id) }}">{{ player.name }}</a></strong>
                    {% if player.risk_reasons|length > 0 %}<br><small>{{ player.risk_reasons }}</small>{% endif %}
                </td>
                <td>{{ i18n.getMessage("player_position_" ~ player.position) }}</td>
                <td>{{ player.age }}</td>
                <td>{{ player.strength_freshness|number_format(0, ',', ' ') }}</td>
                <td>{{ player.strength_stamina|number_format(0, ',', ' ') }}</td>
                <td>
                    <span class="label{% if player.risk_level == 'high' %} label-important{% elseif player.risk_level == 'medium' %} label-warning{% else %} label-success{% endif %}">
                        {{ player.risk }}% - {{ i18n.getMessage("medicalcenter_risk_" ~ player.risk_level) }}
                    </span>
                </td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
{% endif %}

<hr>

<h4>{{ i18n.getMessage("medicalcenter_history") }}</h4>

{% if history|length == 0 %}
    <p>{{ i18n.getMessage("medicalcenter_no_history") }}</p>
{% else %}
    <table class="table table-striped">
        <thead>
            <tr>
                <th>{{ i18n.getMessage("medicalcenter_date") }}</th>
                <th>{{ i18n.getMessage("medicalcenter_player") }}</th>
                <th>{{ i18n.getMessage("medicalcenter_type") }}</th>
                <th>{{ i18n.getMessage("medicalcenter_injury_matches") }}</th>
                <th>{{ i18n.getMessage("medicalcenter_description") }}</th>
            </tr>
        </thead>
        <tbody>
        {% for entry in history %}
            <tr>
                <td>{{ entry.event_date|date(env.getConfig("date_format")) }}</td>
                <td><a href="{{ env.getInternalUrl("player", "id=" ~ entry.player_id) }}">{{ entry.player_name }}</a></td>
                <td>{{ i18n.getMessage("medicalcenter_history_source_" ~ entry.source) }}</td>
                <td>{{ entry.injury_matches }}</td>
                <td>{{ entry.description }}</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
{% endif %}

<div class="alert alert-info">
    <strong>{{ i18n.getMessage("medicalcenter_treatment_risky_cure") }}:</strong>
    {{ i18n.getMessage("medicalcenter_treatment_risky_cure_desc") }}
</div>

{% endif %}

{% endblock %}
