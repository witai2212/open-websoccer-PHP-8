{% extends "base.twig" %}

{% block page_title %}
{{ i18n.getMessage("office_title") }}
{% endblock %}

{% block page_content %}

<style type="text/css">
    .daily-briefing-header {
        margin-bottom: 15px;
    }
    .daily-briefing-header h3 {
        margin-bottom: 3px;
    }
    .daily-briefing-status-card {
        min-height: 118px;
    }
    .daily-briefing-status-card h4 {
        margin-top: 0;
    }
    .daily-briefing-status-value {
        font-size: 26px;
        line-height: 30px;
        font-weight: bold;
        margin-bottom: 8px;
    }
    .daily-briefing-list {
        margin: 0;
        list-style: none;
    }
    .daily-briefing-item {
        padding: 12px 0;
        border-bottom: 1px solid #eee;
    }
    .daily-briefing-item:last-child {
        border-bottom: 0;
    }
    .daily-briefing-item-icon {
        float: left;
        width: 28px;
        padding-top: 2px;
        color: #777;
    }
    .daily-briefing-item-body {
        margin-left: 34px;
    }
    .daily-briefing-item-title {
        margin-bottom: 4px;
    }
    .daily-briefing-meta {
        margin-top: 5px;
    }
    .daily-briefing-actions {
        margin-top: 15px;
    }
</style>

{% if daily_briefing.has_team is not defined or not daily_briefing.has_team %}
    <div class="alert alert-warning">
        <i class="icon-warning-sign"></i>
        {{ i18n.getMessage("feature_requires_team") }}
    </div>
{% else %}

    <div class="daily-briefing-header">
        <h3>{{ i18n.getMessage("dailybriefing_title") }}</h3>
        <p class="muted">
            {{ i18n.getMessage("dailybriefing_intro") }}
            {% if daily_briefing.generated_at > 0 %}
                {{ i18n.getMessage("dailybriefing_generated") }} {{ daily_briefing.generated_at|date(env.getConfig("datetime_format")) }}
            {% endif %}
        </p>
    </div>

    <div class="row-fluid">
        {% for card in daily_briefing.cards %}
            <div class="span3">
                <div class="well daily-briefing-status-card">
                    <h4>{{ card.title }}</h4>
                    <div class="daily-briefing-status-value">{{ card.value }}%</div>
                    <div class="progress">
                        <div class="bar {% if card.css == 'success' %}bar-success{% elseif card.css == 'warning' %}bar-warning{% elseif card.css == 'important' %}bar-danger{% else %}bar-info{% endif %}" style="width: {{ card.value }}%;"></div>
                    </div>
                    <span class="label label-{{ card.css }}">{{ card.label }}</span>
                </div>
            </div>
        {% endfor %}
    </div>

    <div class="well">
        <h4><i class="icon-inbox"></i> {{ i18n.getMessage("dailybriefing_items_title") }}</h4>

        {% if daily_briefing.items|length == 0 %}
            <div class="alert alert-info">{{ i18n.getMessage("dailybriefing_no_items") }}</div>
        {% else %}
            <ul class="daily-briefing-list">
                {% for item in daily_briefing.items %}
                    <li class="daily-briefing-item">
                        <div class="daily-briefing-item-icon">
                            <i class="{{ item.icon }}"></i>
                        </div>
                        <div class="daily-briefing-item-body">
                            <div class="daily-briefing-item-title">
                                <span class="label label-{{ item.priority_css }}">{{ item.priority_label }}</span>
                                <strong>{{ item.title }}</strong>
                            </div>
                            <div>{{ item.message }}</div>
                            <div class="daily-briefing-meta">
                                {% if item.date > 0 %}
                                    <small class="muted">{{ item.date|date(env.getConfig("date_format")) }}</small>
                                    &nbsp;
                                {% endif %}
                                {% if item.link is defined and item.link|length > 0 %}
                                    <a class="btn btn-mini" href="{{ item.link }}">{{ item.link_label }}</a>
                                {% endif %}
                            </div>
                        </div>
                        <div style="clear: both;"></div>
                    </li>
                {% endfor %}
            </ul>
        {% endif %}
    </div>

    <div class="daily-briefing-actions">
        <a class="btn" href="{{ daily_briefing.links.fanpressure }}"><i class="icon-bullhorn"></i> {{ i18n.getMessage("dailybriefing_action_fanpressure") }}</a>
        <a class="btn" href="{{ daily_briefing.links.scouting }}"><i class="icon-search"></i> {{ i18n.getMessage("dailybriefing_action_scouting") }}</a>
        <a class="btn" href="{{ daily_briefing.links.youth_academy }}"><i class="icon-leaf"></i> {{ i18n.getMessage("dailybriefing_action_youth_academy") }}</a>
        <a class="btn" href="{{ daily_briefing.links.loans }}"><i class="icon-retweet"></i> {{ i18n.getMessage("dailybriefing_action_loans") }}</a>
        <a class="btn" href="{{ daily_briefing.links.what_changed }}"><i class="icon-list-alt"></i> {{ i18n.getMessage("dailybriefing_action_whatchanged") }}</a>
    </div>

{% endif %}

{% endblock %}
