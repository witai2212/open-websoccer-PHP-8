{% extends "base.twig" %}

{% block page_title %}
{{ i18n.getMessage("stadium_attendance_title") }}
{% endblock %}

{% block page_content %}

<h3>{{ i18n.getMessage("stadium_attendance_title") }}</h3>
<p>{{ i18n.getMessage("stadium_attendance_intro") }}</p>

{% if attendanceStats is defined and attendanceStats.matches|length > 0 %}

    {% if attendanceStats.summary|length > 0 %}
        <h4>{{ i18n.getMessage("stadium_attendance_average_title") }}</h4>
        <table class="table table-striped table-condensed">
            <thead>
                <tr>
                    <th>{{ i18n.getMessage("stadium_attendance_category") }}</th>
                    <th style="text-align: right;">{{ i18n.getMessage("stadium_attendance_visitors") }}</th>
                    <th style="text-align: right;">{{ i18n.getMessage("stadium_attendance_capacity") }}</th>
                    <th style="text-align: right;">{{ i18n.getMessage("stadium_attendance_utilization") }}</th>
                    <th style="text-align: right;">{{ i18n.getMessage("stadium_attendance_average_price") }}</th>
                    <th style="text-align: right;">{{ i18n.getMessage("stadium_attendance_revenue") }}</th>
                </tr>
            </thead>
            <tbody>
                {% for row in attendanceStats.summary %}
                    <tr{% if row.message_key == 'stadium_attendance_total' %} class="info"{% endif %}>
                        <td><strong>{{ i18n.getMessage(row.message_key) }}</strong></td>
                        <td style="text-align: right;">{{ row.visitors|number_format(0, ',', ' ') }}</td>
                        <td style="text-align: right;">{{ row.capacity|number_format(0, ',', ' ') }}</td>
                        <td style="text-align: right;">{{ row.utilization_percent|number_format(1, ',', ' ') }}%</td>
                        <td style="text-align: right;">{% if row.has_price %}{{ row.average_price|number_format(2, ',', ' ') }} {{ env.getConfig("game_currency") }}{% else %}-{% endif %}</td>
                        <td style="text-align: right;">{% if row.has_price %}{{ row.revenue|number_format(0, ',', ' ') }} {{ env.getConfig("game_currency") }}{% else %}-{% endif %}</td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    {% endif %}

    <h4>{{ i18n.getMessage("stadium_attendance_recent_title") }}</h4>
    <table class="table table-striped table-condensed">
        <thead>
            <tr>
                <th>{{ i18n.getMessage("stadium_attendance_match") }}</th>
                <th>{{ i18n.getMessage("stadium_attendance_category") }}</th>
                <th style="text-align: right;">{{ i18n.getMessage("stadium_attendance_visitors") }}</th>
                <th style="text-align: right;">{{ i18n.getMessage("stadium_attendance_capacity") }}</th>
                <th style="text-align: right;">{{ i18n.getMessage("stadium_attendance_utilization") }}</th>
                <th style="text-align: right;">{{ i18n.getMessage("stadium_attendance_average_price") }}</th>
                <th style="text-align: right;">{{ i18n.getMessage("stadium_attendance_revenue") }}</th>
            </tr>
        </thead>
        <tbody>
            {% for match in attendanceStats.matches %}
                {% for row in match.rows %}
                    <tr{% if row.message_key == 'stadium_attendance_total' %} class="info"{% endif %}>
                        {% if loop.first %}
                            <td rowspan="{{ match.rows|length }}">
                                <strong>{{ env.getFormattedDate(match.match_date) }}</strong><br>
                                <a href="{{ env.getInternalUrl("match", "id=" ~ match.match_id) }}">
                                    {{ i18n.getMessage("stadium_attendance_against") }} {{ match.opponent_name }}
                                </a><br>
                                <small>{{ i18n.getMessage("matchtype_" ~ match.match_type_key) }}{% if match.competition|length > 0 %} - {{ match.competition }}{% endif %}</small>
                                {% if not match.has_snapshot %}<br><small class="muted">{{ i18n.getMessage("stadium_attendance_legacy_hint") }}</small>{% endif %}
                            </td>
                        {% endif %}
                        <td>{{ i18n.getMessage(row.message_key) }}</td>
                        <td style="text-align: right;">{{ row.visitors|number_format(0, ',', ' ') }}</td>
                        <td style="text-align: right;">{{ row.capacity|number_format(0, ',', ' ') }}</td>
                        <td style="text-align: right;">{{ row.utilization_percent|number_format(1, ',', ' ') }}%</td>
                        <td style="text-align: right;">{% if row.has_price %}{{ row.average_price|number_format(2, ',', ' ') }} {{ env.getConfig("game_currency") }}{% else %}-{% endif %}</td>
                        <td style="text-align: right;">{% if row.has_price %}{{ row.revenue|number_format(0, ',', ' ') }} {{ env.getConfig("game_currency") }}{% else %}-{% endif %}</td>
                    </tr>
                {% endfor %}
            {% endfor %}
        </tbody>
    </table>

{% else %}
    <div class="alert alert-warning">
        {{ i18n.getMessage("stadium_attendance_no_matches") }}
    </div>
{% endif %}

{% endblock %}
