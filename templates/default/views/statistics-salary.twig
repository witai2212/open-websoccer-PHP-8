{% block page_content %}

{% if salaries|length == 0 %}
{{ i18n.getMessage("news_no_items") }}
{% else %}

<style>
/* Heading */
#my-chart {
  width: 100%;
  max-width: auto;
  margin: 0 auto;
}

#my-chart caption {
  background-color: hotpink;
  color: white;
}

/* Chart */
#my-chart tbody {
  background-color: beige;
  color: black;
}

/* Labels */
#my-chart tbody th {
  background-color: deepskyblue;
  color: blue;
}

</style>
