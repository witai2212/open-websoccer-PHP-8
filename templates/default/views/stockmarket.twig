{% extends "base.twig" %}

{% block page_title %}
{{ i18n.getMessage("stockmarket_title") }}
{% endblock %}

{% block page_content %}


{% if has_stock_recommendations is defined and not has_stock_recommendations %}
	{{ messagebox.box(i18n.getMessage("stockmarket_recommend_no_advisor"), "", "info") }}
{% endif %}

{% if indexes is defined and indexes|length > 0 %}

	<table class="table table-striped">
		<thead>
			<tr>
				<th>#</th>
				<th>{{ i18n.getMessage("indexes_head_name") }}</th>
				<th>{{ i18n.getMessage("indexes_v1") }}</th>
				<th>{{ i18n.getMessage("indexes_v2") }}</th>
				<th>{{ i18n.getMessage("indexes_v3") }}</th>
				<th>{{ i18n.getMessage("indexes_v4") }}</th>
				<th>{{ i18n.getMessage("indexes_qty") }}</th>
				<th>{{ i18n.getMessage("indexes_ownership") }}</th>
				{% if has_stock_recommendations is defined and has_stock_recommendations %}<th>{{ i18n.getMessage("stockmarket_recommendation") }}</th>{% endif %}
				<th>{{ i18n.getMessage("indexes_buy") }}</th>
			</tr>
		</thead>
		<tbody>
		
			{% for index in indexes %}
			<tr>
				<td><strong>{{ loop.index }}</strong></td>
				<td><p>{% if index.user_qty<index.quantity %}<a href="{{ env.getInternalUrl("stock_chart", "id=" ~ index.id) }}">{{ index.name }} </a>{% else %}{{ index.name }}{% endif %}</p></td>
				<td>
					<p>
						{% if index.v1 > index.v2 %}<i class="icon-chevron-up"></i>
						{% elseif index.v1 < index.v2 %}<i class="icon-chevron-down"></i>
						{% else %}<i class="icon-minus-sign"></i>
						{% endif %}
						
						{{ index.v1 }}
					</p>
				</td>
				<td>{{ index.v2 }}</td>
				<td>{{ index.v3 }}</td>
				<td>{{ index.v4 }}</td>
				<td>{{ index.quantity|number_format(0, ',', ' ') }}</td>
				<td>
					{{ index.owned_percent|number_format(2, ',', ' ') }}%
					{% if index.is_majority_owner %}
						<br><span class="label label-success">{{ i18n.getMessage("stockmarket_majority_owner") }}</span>
					{% endif %}
				</td>
				{% if has_stock_recommendations is defined and has_stock_recommendations %}
				<td>
					{% if index.stock_recommendation is defined %}
						<span class="label label-{{ index.stock_recommendation.label_class }}">{{ i18n.getMessage(index.stock_recommendation.action_key) }}</span><br>
						<small>{{ i18n.getMessage("stockmarket_recommend_confidence") }}: {{ index.stock_recommendation.confidence }}%</small><br>
						<small>{{ i18n.getMessage("stockmarket_recommend_risk") }}: {{ i18n.getMessage(index.stock_recommendation.risk_key) }}</small>
						{% if index.stock_recommendation.reasons is defined and index.stock_recommendation.reasons|length > 0 %}
							<ul class="unstyled" style="margin: 4px 0 0 0;">
							{% for reason in index.stock_recommendation.reasons %}
								<li><small>{{ i18n.getMessage(reason) }}</small></li>
							{% endfor %}
							</ul>
						{% endif %}
					{% endif %}
				</td>
				{% endif %}
				<td>
					<p><a class="btn btn-mini" href="?page=buystock&id={{ index.id }}"><i class="icon-shopping-cart"></i> {{ i18n.getMessage("indexes_buy") }}</a></p>
					{% if index.can_fire_manager %}
					<form method="post" style="margin: 0;">
						<input type="hidden" name="stock_id" value="{{ index.id }}" />
						<input type="hidden" name="action" value="fire_stockcontrolled_manager" />
						<button type="submit" class="btn btn-mini btn-danger"><i class="icon-remove icon-white"></i> {{ i18n.getMessage("stockmarket_fire_manager") }}</button>
					</form>
					{% endif %}
				</td>
					
			</tr>
			{% endfor %}
		
		</tbody>
	</table>

{% else %}
	{{ messagebox.box(i18n.getMessage("no_stockmarket_indexes"), "", "info") }}
{% endif %}

{% endblock %}