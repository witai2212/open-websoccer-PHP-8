{% extends "base.twig" %}

{% block page_title %}
{{ i18n.getMessage("trainingcalendar_title") }}
{% endblock %}

{% block page_content %}

<h3>{{ i18n.getMessage("trainingcalendar_title") }}</h3>
<p>{{ i18n.getMessage("trainingcalendar_intro") }}</p>

{% if not advancedTrainingEnabled %}
    <div class="alert alert-warning">{{ i18n.getMessage("trainingcalendar_disabled") }}</div>
{% endif %}

{% if activeCamp is defined and activeCamp|length > 0 %}
    <div class="alert alert-info">
        <strong>{{ i18n.getMessage("trainingcalendar_active_camp") }}:</strong>
        {{ activeCamp.name }} ({{ env.getFormattedDate(activeCamp.date_start) }} - {{ env.getFormattedDate(activeCamp.date_end) }}).<br>
        {{ i18n.getMessage("trainingcalendar_active_camp_note") }}
    </div>
{% elseif unitsCount < 1 %}
    <div class="alert alert-warning">
        {{ i18n.getMessage("trainingcalendar_no_units_warning") }}
        <a href="{{ env.getInternalUrl("training") }}">{{ i18n.getMessage("trainingcalendar_go_to_training") }}</a>
    </div>
{% endif %}

<div class="row-fluid">
    <div class="span4">
        <div class="well">
            <h4>{{ i18n.getMessage("trainingcalendar_next_focus") }}</h4>
            {% if currentSlot is defined and currentSlot|length > 0 %}
                <p><strong>{{ i18n.getMessage(trainingTypes[currentSlot.training_type].label_key) }}</strong></p>
                <p>{{ i18n.getMessage("training_plan_slot") }} {{ currentSlotNo }} / {{ trainingSlotNumbers|length }}</p>
            {% else %}
                <p>-</p>
            {% endif %}
        </div>
    </div>
    <div class="span4">
        <div class="well">
            <h4>{{ i18n.getMessage("training_execute_intensity") }}</h4>
            {% if currentSlot is defined and currentSlot|length > 0 %}
                <p><strong>{{ currentSlot.intensity }} %</strong> - {{ i18n.getMessage(currentSlot.preview.intensity_label_key) }}</p>
                <p>{{ i18n.getMessage("trainingcalendar_open_units") }}: {{ unitsCount }}</p>
            {% else %}
                <p>-</p>
            {% endif %}
        </div>
    </div>
    <div class="span4">
        <div class="well">
            <h4>{{ i18n.getMessage("trainingcalendar_team_chemistry") }}</h4>
            <p><strong>{{ teamChemistry }} %</strong></p>
            {% if currentSlot is defined and currentSlot.preview is defined %}
                <p>{{ i18n.getMessage("trainingcalendar_expected_chemistry") }}: {{ currentSlot.preview.chemistry_signed }}</p>
            {% endif %}
        </div>
    </div>
</div>

<div class="row-fluid">
    <div class="span6">
        <div class="well">
            <h4>{{ i18n.getMessage("trainingcalendar_expected_effects") }}</h4>
            {% if currentSlot is defined and currentSlot.preview.main_effects|length > 0 %}
                <ul>
                    {% for effect in currentSlot.preview.main_effects %}
                        <li>{{ i18n.getMessage(effect.label_key) }}: {{ effect.signed }}</li>
                    {% endfor %}
                </ul>
            {% else %}
                <p>{{ i18n.getMessage("trainingcalendar_no_expected_effects") }}</p>
            {% endif %}
        </div>
    </div>
    <div class="span6">
        <div class="well">
            <h4>{{ i18n.getMessage("trainingcalendar_injury_risk") }}</h4>
            {% if currentSlot is defined and currentSlot.preview is defined %}
                {% set riskKey = currentSlot.preview.injury_risk_label_key %}
                <p>
                    <span class="label{% if riskKey == 'trainingcalendar_risk_high' %} label-important{% elseif riskKey == 'trainingcalendar_risk_medium' %} label-warning{% elseif riskKey == 'trainingcalendar_risk_low' %} label-info{% endif %}">
                        {{ i18n.getMessage(riskKey) }}
                    </span>
                    {{ currentSlot.preview.injury_risk_display }} {{ i18n.getMessage("trainingcalendar_per_player") }}
                </p>
            {% endif %}
            {% if trainer is defined and trainer|length > 0 %}
                <p>{{ i18n.getMessage("trainingcalendar_current_trainer") }}: <strong>{{ trainer.name }}</strong></p>
            {% else %}
                <p>{{ i18n.getMessage("trainingcalendar_no_trainer") }}</p>
            {% endif %}
        </div>
    </div>
</div>

<h3>{{ i18n.getMessage("trainingcalendar_plan_title") }}</h3>
<p>{{ i18n.getMessage("trainingcalendar_plan_intro") }}</p>

<form class="form-horizontal" method="post">
    <div style="overflow-x: auto;">
        <table class="table table-striped table-condensed">
            <thead>
                <tr>
                    <th>{{ i18n.getMessage("training_plan_slot") }}</th>
                    <th>{{ i18n.getMessage("training_plan_type") }}</th>
                    <th>{{ i18n.getMessage("training_execute_intensity") }}</th>
                    <th>{{ i18n.getMessage("trainingcalendar_expected_effects") }}</th>
                    <th>{{ i18n.getMessage("trainingcalendar_expected_chemistry") }}</th>
                    <th>{{ i18n.getMessage("trainingcalendar_injury_risk") }}</th>
                </tr>
            </thead>
            <tbody>
                {% for slotNo in trainingSlotNumbers %}
                    {% set slot = trainingPlanSlots[slotNo] %}
                    <tr{% if slot.is_current %} class="info"{% endif %}>
                        <td>
                            <strong>{{ slotNo }}</strong>
                            {% if slot.is_current %}<br><span class="label label-info">{{ i18n.getMessage("trainingcalendar_next") }}</span>{% endif %}
                        </td>
                        <td>
                            <select name="type_{{ slotNo }}" class="input-large">
                                {% for typeId,typeInfo in trainingTypes %}
                                    <option value="{{ typeId }}"{% if typeId == slot.training_type %} selected{% endif %}>{{ i18n.getMessage(typeInfo.label_key) }}</option>
                                {% endfor %}
                            </select>
                        </td>
                        <td>
                            <input type="number" name="intensity_{{ slotNo }}" min="1" max="100" value="{{ slot.intensity }}" class="input-mini" /> %<br>
                            <small>{{ i18n.getMessage(slot.preview.intensity_label_key) }}</small>
                        </td>
                        <td>
                            {% if slot.preview.main_effects|length > 0 %}
                                {% for effect in slot.preview.main_effects %}
                                    {% if loop.index > 1 %}<br>{% endif %}{{ i18n.getMessage(effect.label_key) }}: {{ effect.signed }}
                                {% endfor %}
                            {% else %}
                                -
                            {% endif %}
                        </td>
                        <td>{{ slot.preview.chemistry_signed }}</td>
                        <td>
                            {% set riskKey = slot.preview.injury_risk_label_key %}
                            <span class="label{% if riskKey == 'trainingcalendar_risk_high' %} label-important{% elseif riskKey == 'trainingcalendar_risk_medium' %} label-warning{% elseif riskKey == 'trainingcalendar_risk_low' %} label-info{% endif %}">{{ i18n.getMessage(riskKey) }}</span><br>
                            <small>{{ slot.preview.injury_risk_display }}</small>
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>

    <div class="form-actions">
        <button type="submit" class="btn btn-primary"><i class="icon-ok icon-white"></i> {{ i18n.getMessage('button_save') }}</button>
        <a class="btn" href="{{ env.getInternalUrl("training") }}"><i class="icon-user"></i> {{ i18n.getMessage("trainingcalendar_go_to_training") }}</a>
        <a class="btn" href="{{ env.getInternalUrl("trainingcamp") }}"><i class="icon-plane"></i> {{ i18n.getMessage("trainingcalendar_go_to_camps") }}</a>
    </div>
    <input type="hidden" name="page" value="training-calendar" />
    <input type="hidden" name="action" value="save-training-plan" />
    <input type="hidden" name="returnpage" value="training-calendar" />
</form>

<h3>{{ i18n.getMessage("trainingcalendar_last_report_title") }}</h3>
{% if latestTrainingReport is defined and latestTrainingReport.id is defined %}
    <table class="table table-striped">
        <tbody>
            <tr>
                <th>{{ i18n.getMessage("training_report_date") }}</th>
                <td>{{ env.getFormattedDatetime(latestTrainingReport.created_date) }}</td>
            </tr>
            <tr>
                <th>{{ i18n.getMessage("training_plan_type") }}</th>
                <td>{{ i18n.getMessage(trainingTypes[latestTrainingReport.training_type].label_key) }}</td>
            </tr>
            <tr>
                <th>{{ i18n.getMessage("training_execute_intensity") }}</th>
                <td>{{ latestTrainingReport.intensity }} %</td>
            </tr>
            <tr>
                <th>{{ i18n.getMessage("training_report_player_count") }}</th>
                <td>{{ latestTrainingReport.player_count }}</td>
            </tr>
            <tr>
                <th>{{ i18n.getMessage("training_report_injuries") }}</th>
                <td>{{ latestTrainingReport.injuries }}</td>
            </tr>
            <tr>
                <th>{{ i18n.getMessage("training_report_chemistry") }}</th>
                <td>{{ latestTrainingReport.old_chemistry }} → {{ latestTrainingReport.new_chemistry }} ({{ latestTrainingReport.chemistry_change }})</td>
            </tr>
        </tbody>
    </table>

    <div class="row-fluid">
        <div class="span6">
            <div class="well">
                <h4>{{ i18n.getMessage("trainingcalendar_best_performer") }}</h4>
                {% if bestPerformer is defined and bestPerformer|length > 0 %}
                    <p><a href="{{ env.getInternalUrl("player", "id=" ~ bestPerformer.player_id) }}">{{ bestPerformer.name }}</a></p>
                    <p>{{ i18n.getMessage("trainingcalendar_total_effect") }}: {{ bestPerformer.total_effect }}</p>
                {% else %}
                    <p>-</p>
                {% endif %}
            </div>
        </div>
        <div class="span6">
            <div class="well">
                <h4>{{ i18n.getMessage("trainingcalendar_worst_performer") }}</h4>
                {% if worstPerformer is defined and worstPerformer|length > 0 %}
                    <p><a href="{{ env.getInternalUrl("player", "id=" ~ worstPerformer.player_id) }}">{{ worstPerformer.name }}</a></p>
                    <p>{{ i18n.getMessage("trainingcalendar_total_effect") }}: {{ worstPerformer.total_effect }}{% if worstPerformer.injured == '1' %} <span class="label label-important">{{ i18n.getMessage("training_report_injured") }}</span>{% endif %}</p>
                {% else %}
                    <p>-</p>
                {% endif %}
            </div>
        </div>
    </div>
{% else %}
    <p>{{ i18n.getMessage("trainingcalendar_no_report") }}</p>
{% endif %}

<h3>{{ i18n.getMessage("trainingcalendar_camps_title") }}</h3>
{% if futureCamps is defined and futureCamps|length > 0 %}
    <table class="table table-striped table-condensed">
        <thead>
            <tr>
                <th>{{ i18n.getMessage("entity_trainingcamp_name") }}</th>
                <th>{{ i18n.getMessage("trainingcamp_report_period") }}</th>
                <th>{{ i18n.getMessage("entity_trainingcamp_camp_type") }}</th>
                <th>{{ i18n.getMessage("trainingcalendar_expected_effects") }}</th>
                <th>{{ i18n.getMessage("trainingcalendar_injury_risk") }}</th>
                <th>{{ i18n.getMessage("trainingcalendar_status") }}</th>
            </tr>
        </thead>
        <tbody>
        {% for camp in futureCamps %}
            <tr{% if camp.is_active %} class="info"{% endif %}>
                <td>{{ camp.name }}</td>
                <td>{{ env.getFormattedDate(camp.date_start) }} - {{ env.getFormattedDate(camp.date_end) }}</td>
                <td>{{ i18n.getMessage("trainingcamp_type_" ~ camp.camp_type) }}</td>
                <td>
                    {{ i18n.getMessage("trainingcalendar_effect_strength") }}: {{ camp.effect_strength }},
                    {{ i18n.getMessage("trainingcalendar_effect_technique") }}: {{ camp.effect_strength_technique }},
                    {{ i18n.getMessage("trainingcalendar_effect_stamina") }}: {{ camp.effect_strength_stamina }},
                    {{ i18n.getMessage("trainingcalendar_effect_freshness") }}: {{ camp.effect_strength_freshness }},
                    {{ i18n.getMessage("trainingcalendar_effect_satisfaction") }}: {{ camp.effect_strength_satisfaction }},
                    {{ i18n.getMessage("trainingcalendar_expected_chemistry") }}: {{ camp.effect_team_chemistry }}
                </td>
                <td>{{ camp.injury_risk }} %</td>
                <td>{% if camp.is_active %}<span class="label label-info">{{ i18n.getMessage("trainingcalendar_status_active") }}</span>{% else %}<span class="label">{{ i18n.getMessage("trainingcalendar_status_upcoming") }}</span>{% endif %}</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
{% else %}
    <p>{{ i18n.getMessage("trainingcalendar_no_camps") }} <a href="{{ env.getInternalUrl("trainingcamp") }}">{{ i18n.getMessage("trainingcalendar_go_to_camps") }}</a></p>
{% endif %}

{% if lastCampReport is defined and lastCampReport|length > 0 %}
    <h4>{{ i18n.getMessage("trainingcalendar_last_camp_report") }}</h4>
    <table class="table table-striped table-condensed">
        <tbody>
            <tr>
                <th>{{ i18n.getMessage("entity_trainingcamp_name") }}</th>
                <td>{{ lastCampReport.camp_name }}</td>
            </tr>
            <tr>
                <th>{{ i18n.getMessage("trainingcamp_report_period") }}</th>
                <td>{{ env.getFormattedDate(lastCampReport.date_start) }} - {{ env.getFormattedDate(lastCampReport.date_end) }}</td>
            </tr>
            <tr>
                <th>{{ i18n.getMessage("trainingcamp_report_effects") }}</th>
                <td>
                    {{ i18n.getMessage("entity_trainingcamp_p_staerke") }}: {{ lastCampReport.effect_strength_signed }},
                    {{ i18n.getMessage("entity_trainingcamp_p_technik") }}: {{ lastCampReport.effect_technique_signed }},
                    {{ i18n.getMessage("entity_trainingcamp_p_kondition") }}: {{ lastCampReport.effect_stamina_signed }},
                    {{ i18n.getMessage("entity_trainingcamp_p_frische") }}: {{ lastCampReport.effect_freshness_signed }},
                    {{ i18n.getMessage("entity_trainingcamp_p_zufriedenheit") }}: {{ lastCampReport.effect_satisfaction_signed }},
                    {{ i18n.getMessage("entity_trainingcamp_p_team_chemistry") }}: {{ lastCampReport.effect_chemistry_signed }}
                </td>
            </tr>
            <tr>
                <th>{{ i18n.getMessage("trainingcamp_report_injuries") }}</th>
                <td>{{ lastCampReport.injuries }}</td>
            </tr>
        </tbody>
    </table>
{% endif %}

{% endblock %}
