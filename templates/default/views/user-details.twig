{% import "macros/profileelements.twig" as profile %}
{% import "macros/messagebox.twig" as messagebox %}
{% import "macros/badges.twig" as badgesmacros %}
{% extends "base.twig" %}

{% block page_title %}
	{{ user.nick }}
{% endblock %}

{% block page_content %}

	<style type="text/css">
		#user-profile-main-stats {
			display: -webkit-box;
			display: -webkit-flex;
			display: -ms-flexbox;
			display: flex;
			-webkit-flex-wrap: nowrap;
			-ms-flex-wrap: nowrap;
			flex-wrap: nowrap;
			-webkit-box-align: stretch;
			-webkit-align-items: stretch;
			-ms-flex-align: stretch;
			align-items: stretch;
			gap: 12px;
			width: 100%;
		}
		#user-profile-main-stats .user-profile-stat-card-five {
			-webkit-box-flex: 1;
			-webkit-flex: 1 1 0;
			-ms-flex: 1 1 0;
			flex: 1 1 0;
			width: 0;
			min-width: 0;
			margin-left: 0 !important;
		}
		@media (max-width: 767px) {
			#user-profile-main-stats {
				-webkit-flex-wrap: wrap;
				-ms-flex-wrap: wrap;
				flex-wrap: wrap;
			}
			#user-profile-main-stats .user-profile-stat-card-five {
				-webkit-box-flex: 1;
				-webkit-flex: 1 1 42%;
				-ms-flex: 1 1 42%;
				flex: 1 1 42%;
				width: auto;
			}
		}
	</style>

	<div class="user-profile-hero">
		<div class="user-profile-hero-avatar">
			{% if user.picture|length > 0 %}
				<img src="{{ user.picture }}" alt="{{ user.nick }}" />
			{% else %}
				<i class="icon-user"></i>
			{% endif %}
		</div>
		<div class="user-profile-hero-main">
			<div class="user-profile-title-row">
				<h2>{{ user.nick }}</h2>
				{% if user.is_online %}
					<span class="label label-success"><i class="icon-ok-sign"></i> {{ i18n.getMessage("user_profile_online") }}</span>
				{% else %}
					<span class="label"><i class="icon-time"></i> {{ i18n.getMessage("entity_users_lastonline") }}: {{ env.getFormattedDate(user.lastonline) }}</span>
				{% endif %}
			</div>
			<p class="user-profile-subline">
				<i class="icon-calendar"></i> {{ i18n.getMessage("entity_users_datum_anmeldung") }}: {{ env.getFormattedDate(user.registration_date) }}
				{% if userteams|length > 0 %}
					<span class="user-profile-dot">&bull;</span> <i class="icon-flag"></i> {{ i18n.getMessage("entity_club") }}: {{ userteams[0].name }}{% if userteams|length > 1 %} +{{ userteams|length - 1 }}{% endif %}
				{% endif %}
			</p>
			{% if user.id == env.user.id %}
				<div class="user-profile-actions">
					<a href="{{ env.getInternalUrl("profile") }}" class="btn"><i class="icon-edit"></i> {{ i18n.getMessage("button_edit") }}</a>
					{% if env.getConfig("user_picture_upload_enabled") %}
						<a href="{{ env.getInternalUrl("change-profile-picture") }}" class="btn btn-small"><i class="icon-upload"></i> {{ i18n.getMessage("user_changepicture_button") }}</a>
						{% if user.picture_uploadfile|length > 0 %}
							<a href="{{ env.getInternalActionUrl("delete-profile-picture") }}" class="btn btn-small"><i class="icon-remove"></i> {{ i18n.getMessage("user_deletepicture_button") }}</a>
						{% endif %}
					{% endif %}
					{% if env.getConfig("gravatar_enable") %}
						<a href="http://{{ i18n.getCurrentLanguage() }}.gravatar.com" target="_blank" title="{{ i18n.getMessage("gravatar_edit_picture") }}" class="btn btn-small"><i class="icon-external-link"></i> {{ i18n.getMessage("gravatar_edit_picture_button") }}</a>
					{% endif %}
				</div>
			{% endif %}
		</div>
	</div>
	
	{% if absence %}
	{{ messagebox.box("", i18n.getMessage("absence_profile_info", env.getFormattedDate(absence.to_date)), "warning") }}
{% endif %}

<ul class="nav nav-tabs" id="userTab">
  <li class="active"><a href="#general" data-toggle="tab">{{ i18n.getMessage("user_tab_profile") }}</a></li>
  <li><a href="#activities" data-toggle="tab" class="ajaxLink"
  	data-ajaxtarget="activitieslist" data-ajaxblock="user-activities" data-ajaxquerystr="userid={{ user.id }}">{{ i18n.getMessage("activities_tab") }}</a></li>
  <li><a href="#results" data-toggle="tab" class="ajaxLink"
  	data-ajaxtarget="resultslist" data-ajaxblock="user-results" data-ajaxquerystr="userid={{ user.id }}">{{ i18n.getMessage("results_tab_latest_results") }}</a></li>
  {% if env.getConfig("transfermarket_enabled") or env.getConfig("transferoffers_enabled") %}
  <li><a href="#transfers" data-toggle="tab" class="ajaxLink"
  	data-ajaxtarget="transferslist" data-ajaxblock="usertransfers" data-ajaxquerystr="userid={{ user.id }}">{{ i18n.getMessage("transfers_tab") }}</a></li>
  {% endif %}
  <li><a href="#badges" data-toggle="tab">{{ i18n.getMessage("badges_navlabel") }}</a></li>
  {% if career.enabled %}
  <!-- <li><a href="#managercareer" data-toggle="tab">{{ i18n.getMessage("managercareer_tab") }}</a></li>-->
  {% endif %}
  <li><a href="#history" data-toggle="tab" class="ajaxLink"
  	data-ajaxtarget="historycontent" data-ajaxblock="user-history" data-ajaxquerystr="userid={{ user.id }}">{{ i18n.getMessage("history_tab") }}</a></li>
  
</ul>

<div class="tab-content">
  <div class="tab-pane active" id="general">
  
		{% if userteams|length > 1 %}
			{% set team = "<ul class=\"unstyled user-profile-link-list\">" %}
			{% for userteam in userteams %}
				{% set team = team ~ "<li><a href=\"" ~ env.getInternalUrl("team", "id=" ~ userteam.id) ~ "\">" ~ userteam.name|e ~ "</a></li>" %}
			{% endfor %}
			{% set team = team ~ "</ul>" %}
		{% elseif userteams|length == 1 %}
			{% set team = "<a href=\"" ~ env.getInternalUrl("team", "id=" ~ userteams[0].id) ~ "\">" ~ userteams[0].name|e ~ "</a>" %}
		{% else %}
			{% set team = "-" %}
		{% endif %}

		<div id="user-profile-main-stats" class="row-fluid user-profile-stat-row user-profile-stat-row-five">
			<div class="user-profile-stat-card user-profile-stat-card-five">
				<span class="user-profile-stat-icon"><i class="icon-flag"></i></span>
				<span class="user-profile-stat-label">{{ i18n.getMessage("entity_club") }}</span>
				<span class="user-profile-stat-value">{% if userteams|length > 0 %}{{ userteams|length }}{% else %}-{% endif %}</span>
			</div>
			<div class="user-profile-stat-card user-profile-stat-card-five">
				<span class="user-profile-stat-icon"><i class="icon-star"></i></span>
				<span class="user-profile-stat-label">{{ i18n.getMessage("entity_users_highscore") }}</span>
				<span class="user-profile-stat-value">{{ user.highscore }}</span>
			</div>
			<div class="user-profile-stat-card user-profile-stat-card-five">
				<span class="user-profile-stat-icon"><i class="icon-trophy"></i></span>
				<span class="user-profile-stat-label">{{ i18n.getMessage("entity_users_reputation") }}</span>
				<span class="user-profile-stat-value">{{ user.reputation|default(0) }}</span>
			</div>
			<div class="user-profile-stat-card user-profile-stat-card-five">
				<span class="user-profile-stat-icon"><i class="icon-heart"></i></span>
				<span class="user-profile-stat-label">{{ i18n.getMessage("entity_users_fanbeliebtheit") }}</span>
				<span class="user-profile-stat-value">{{ user.popularity }}%</span>
			</div>
			<div class="user-profile-stat-card user-profile-stat-card-five">
				<span class="user-profile-stat-icon"><i class="icon-certificate"></i></span>
				<span class="user-profile-stat-label">{{ i18n.getMessage("user_profile_manager_competence") }}</span>
				<span class="user-profile-stat-value">{{ user.manager_competence|default(10) }}/20</span>
			</div>
		</div>

		<div class="row-fluid user-profile-section-row">
			<div class="span6">
				<div class="user-profile-panel">
					<h4><i class="icon-flag"></i> {{ i18n.getMessage("user_profile_clubs_title") }}</h4>
					{% if userteams|length > 0 %}
						<ul class="unstyled user-profile-club-list">
						{% for userteam in userteams %}
							<li>
								{% if userteam.bild|length %}
									<img src="{{ env.getConfig("context_root") }}/uploads/club/{{ userteam.bild }}" alt="{{ userteam.name }}" />
								{% else %}
									<span class="user-profile-club-placeholder"><i class="icon-shield"></i></span>
								{% endif %}
								<a href="{{ env.getInternalUrl("team", "id=" ~ userteam.id) }}">{{ userteam.name }}</a>
							</li>
						{% endfor %}
						</ul>
					{% else %}
						<p class="muted">{{ i18n.getMessage("user_profile_no_club") }}</p>
					{% endif %}
					{% if user.nationalteam is defined %}
						<div class="user-profile-national-team">
							<strong>{{ i18n.getMessage("nationalteams_team_label") }}:</strong>
							<a href="{{ env.getInternalUrl("team", "id=" ~ user.nationalteam.id) }}">{{ user.nationalteam.name }}</a>
						</div>
					{% endif %}
				</div>
			</div>
			<div class="span6">
				<div class="user-profile-panel">
					<h4><i class="icon-time"></i> {{ i18n.getMessage("user_profile_activity_title") }}</h4>
					{{ profile.infofield(i18n.getMessage("entity_users_datum_anmeldung"), env.getFormattedDate(user.registration_date)) }}
					{{ profile.infofield(i18n.getMessage("user_profile_membership_days"), user.membership_days ~ " " ~ i18n.getMessage("unit_days")) }}
					{{ profile.infofield(i18n.getMessage("entity_users_lastonline"), env.getFormattedDate(user.lastonline)) }}
					{{ profile.infofield(i18n.getMessage("user_profile_profile_completed"), user.profile_fields_filled ~ " / " ~ user.profile_fields_total) }}
				</div>
			</div>
		</div>

		<div class="user-profile-panel">
			<h4><i class="icon-user"></i> {{ i18n.getMessage("user_profile_personal_title") }}</h4>
			{% if user.name|length > 0 or user.place|length > 0 or user.country|length > 0 or user.birthday > 0 or user.occupation|length > 0 or user.interests|length > 0 or user.favorite_club|length > 0 or user.homepage|length > 0 %}
				<div class="row-fluid">
					<div class="span6">
						{% if user.name|length > 0 %}{{ profile.infofield(i18n.getMessage("entity_users_name"), user.name) }}{% endif %}
						{% if user.place|length > 0 %}{{ profile.infofield(i18n.getMessage("entity_users_wohnort"), user.place) }}{% endif %}
						{% if user.country|length > 0 %}{{ profile.infofield(i18n.getMessage("entity_users_land"), user.country) }}{% endif %}
						{% if user.birthday > 0 %}{{ profile.infofield(i18n.getMessage("entity_users_geburtstag"), user.birthday|date(env.getConfig("date_format"))) }}{% endif %}
					</div>
					<div class="span6">
						{% if user.occupation|length > 0 %}{{ profile.infofield(i18n.getMessage("entity_users_beruf"), user.occupation) }}{% endif %}
						{% if user.interests|length > 0 %}{{ profile.infofield(i18n.getMessage("entity_users_interessen"), user.interests) }}{% endif %}
						{% if user.favorite_club|length > 0 %}{{ profile.infofield(i18n.getMessage("entity_users_lieblingsverein"), user.favorite_club) }}{% endif %}
						{% if user.homepage|length > 0 %}
							{% set websiteLink = "<a href=\"" ~ user.homepage ~ "\" target=\"_blank\">" ~ i18n.getMessage("user_visit_website") ~ "</a>" %}
							{{ profile.infofield(i18n.getMessage("entity_users_homepage"), websiteLink, true) }}
						{% endif %}
					</div>
				</div>
			{% else %}
				<p class="muted">{{ i18n.getMessage("user_profile_no_personal_details") }}</p>
			{% endif %}
		</div>
  
  </div>
  
  <div class="tab-pane" id="activities">
  	<div id="activitieslist"></div>
  </div>
  
  <div class="tab-pane" id="results">
  	<div id="resultslist"></div>
  </div>
  
  {% if env.getConfig("transfermarket_enabled") or env.getConfig("transferoffers_enabled") %}
  <div class="tab-pane" id="transfers">
  	<div id="transferslist"></div>
  </div>
  {% endif %}
  
  <div class="tab-pane" id="badges">
  	{% if badges|length > 0 %}
  		<table class="table table-striped table-condensed">
  			<thead>
  				<tr>
  					<th>Auszeichnung</th>
  					<th>Beschreibung</th>
  					<th>Status</th>
  					<th>Erhalten</th>
  				</tr>
  			</thead>
  			<tbody>
  			{% for badge in badges %}
  				<tr{% if badge.earned_count < 1 %} class="muted"{% endif %}>
  					<td>
  						{% if badge.earned_count > 0 %}
  							{{ badgesmacros.badge(badge.name, badge.level, badge.last_rewarded) }}
  						{% else %}
  							{{ badgesmacros.badge(badge.name, badge.level) }}
  						{% endif %}
  					</td>
  					<td>
  						{% if badge.description|length and i18n.hasMessage(badge.description) %}
  							{{ i18n.getMessage(badge.description) }}
  						{% else %}
  							{{ badge.description }}
  						{% endif %}
  					</td>
  					<td>
  						{% if badge.event_benchmark > 0 %}
  							{{ badge.current_status|default(0) }}{% if badge.event == 'transfer_master' %}%{% endif %} / {{ badge.event_benchmark }}{% if badge.event == 'transfer_master' %}%{% endif %}
  						{% else %}
  							{{ badge.current_status|default(0) }}
  						{% endif %}
  					</td>
  					<td>{% if badge.earned_count > 0 %}{{ badge.earned_count }}x{% else %}-{% endif %}</td>
  				</tr>
  			{% endfor %}
  			</tbody>
  		</table>
  	{% else %}
  		<p class="muted">Keine Auszeichnungen konfiguriert.</p>
  	{% endif %}
  </div>
  

  {% if career.enabled %}
  <div class="tab-pane" id="managercareer">
    <div class="row-fluid">
      <div class="span4">
        <div class="well">
          <h4>{{ i18n.getMessage("managercareer_reputation") }}</h4>
          <p style="font-size: 28px; line-height: 32px;"><strong>{{ career.manager_score }}</strong></p>
          <p class="muted">{{ i18n.getMessage("managercareer_reputation_help") }}</p>
          <ul class="unstyled">
            <li>{{ i18n.getMessage("entity_users_highscore") }}: {{ career.user_highscore }}</li>
            <li>{{ i18n.getMessage("managercareer_board_average") }}: {% if career.avg_board_satisfaction > 0 %}{{ career.avg_board_satisfaction }}%{% else %}-{% endif %}</li>
            <li>Karrierestationen: {{ career.history|length }}</li>
            {% if career.is_own_profile %}
              <li>Offene Bewerbungen: {{ career.application_open_count|default(0) }} / {{ career.application_limit|default(3) }}</li>
              <li>Aktive Jobangebote: {{ career.open_offers|length }}</li>
            {% endif %}
          </ul>
        </div>
      </div>
      <div class="span8">
        <h4>{{ i18n.getMessage("managercareer_current_teams") }}</h4>
        {% if career.teams|length > 0 %}
          <ul>
          {% for team in career.teams %}
            <li>
              <a href="{{ env.getInternalUrl("team", "id=" ~ team.id) }}">{{ team.name }}</a>
              - {{ i18n.getMessage("managercareer_board_satisfaction") }}: {{ team.board_satisfaction }}%
            </li>
          {% endfor %}
          </ul>
        {% else %}
          <p class="muted">{{ i18n.getMessage("managercareer_no_current_team") }}</p>
        {% endif %}

        {% if career.is_own_profile %}
          <div class="alert alert-info">
            Die Managerkarriere im Profil ist nur noch eine kompakte Übersicht. Bewerbungen, Jobangebote, Ziele, Verträge und Aktionen werden im Büro verwaltet.
          </div>
          <p>
            <a href="{{ env.getInternalUrl("managercareer") }}" class="btn btn-primary"><i class="icon-briefcase"></i> {{ i18n.getMessage("managercareer_page_title") }}</a>
          </p>
        {% endif %}
      </div>
    </div>

    {% if career.history|length > 0 %}
      <h4>{{ i18n.getMessage("managercareer_history_title") }}</h4>
      <table class="table table-striped table-condensed">
        <thead>
          <tr>
            <th>{{ i18n.getMessage("managercareer_date") }}</th>
            <th>{{ i18n.getMessage("managercareer_old_club") }}</th>
            <th>{{ i18n.getMessage("managercareer_new_club") }}</th>
            <th>{{ i18n.getMessage("managercareer_origin") }}</th>
          </tr>
        </thead>
        <tbody>
        {% for item in career.history|slice(0, 5) %}
          <tr>
            <td>{{ env.getFormattedDate(item.change_date) }}</td>
            <td>{% if item.old_team_id > 0 %}<a href="{{ env.getInternalUrl("team", "id=" ~ item.old_team_id) }}">{{ item.old_team_name }}</a>{% else %}-{% endif %}</td>
            <td>{% if item.new_team_id > 0 %}<a href="{{ env.getInternalUrl("team", "id=" ~ item.new_team_id) }}">{{ item.new_team_name }}</a>{% else %}-{% endif %}</td>
            <td>{{ i18n.getMessage("managercareer_origin_" ~ item.origin) }}</td>
          </tr>
        {% endfor %}
        </tbody>
      </table>
    {% else %}
      <p class="muted">{{ i18n.getMessage("managercareer_no_history") }}</p>
    {% endif %}
  </div>
  {% endif %}

  <div class="tab-pane" id="history">
  	<div id="historycontent"></div>
  </div>
</div>

{% endblock %}