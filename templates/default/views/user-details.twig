{% import "macros/profileelements.twig" as profile %}
{% import "macros/messagebox.twig" as messagebox %}
{% import "macros/badges.twig" as badgesmacros %}
{% extends "base.twig" %}

{% block page_title %}
	{{ user.nick }}
{% endblock %}

{% block page_content %}

<div style="text-align: center; margin-bottom: 10px;">

	{% if user.picture|length > 0 %}
		<img src="{{ user.picture }}" class="img-rounded" style="width:120px;height:120px"/>
	{% endif %}

	{% if user.id == env.user.id %}
		<p style="text-align: center; margin-top: 10px;">
		
		{% if env.getConfig("user_picture_upload_enabled") %}
			<a href="{{ env.getInternalUrl("change-profile-picture") }}" class="btn btn-small">
				<i class="icon-upload"></i> {{ i18n.getMessage("user_changepicture_button") }}
			</a>
			{% if user.picture_uploadfile|length > 0 %}
				<a href="{{ env.getInternalActionUrl("delete-profile-picture") }}" class="btn btn-small">
					<i class="icon-remove"></i> {{ i18n.getMessage("user_deletepicture_button") }}
				</a>
			{% endif %}
		{% endif %}
		
		{% if env.getConfig("gravatar_enable") %}
			<a href="http://{{ i18n.getCurrentLanguage() }}.gravatar.com" target="_blank" 
				title="{{ i18n.getMessage("gravatar_edit_picture") }}" class="btn btn-small">
				<i class="icon-external-link"></i> {{ i18n.getMessage("gravatar_edit_picture_button") }}
			</a>
		{% endif %}
		
		</p>
	{% endif %}
</div>

{% if absence %}
	{{ messagebox.box("", i18n.getMessage("absence_profile_info", env.getFormattedDate(absence.to_date)), "warning") }}
{% endif %}

<ul class="nav nav-tabs" id="userTab">
  <li class="active"><a href="#general" data-toggle="tab">{{ i18n.getMessage("user_tab_profile") }}</a></li>
  <li><a href="#activities" data-toggle="tab" class="ajaxLink"
  	data-ajaxtarget="activitieslist" data-ajaxblock="user-activities" data-ajaxquerystr="userid={{ user.id }}">{{ i18n.getMessage("activities_tab") }}</a></li>
  <li><a href="#results" data-toggle="tab" class="ajaxLink"
  	data-ajaxtarget="resultslist" data-ajaxblock="user-results" data-ajaxquerystr="userid={{ user.id }}">{{ i18n.getMessage("results_tab_latest_results") }}</a></li>
  {% if env.getConfig("transfermarket_enabled") or env.getConfig("transferoffers_enabled") %}
  <li><a href="#transfers" data-toggle="tab" class="ajaxLink"
  	data-ajaxtarget="transferslist" data-ajaxblock="usertransfers" data-ajaxquerystr="userid={{ user.id }}">{{ i18n.getMessage("transfers_tab") }}</a></li>
  {% endif %}
  <li><a href="#badges" data-toggle="tab">{{ i18n.getMessage("badges_navlabel") }}</a></li>
  {% if career.enabled %}
  <li><a href="#managercareer" data-toggle="tab">{{ i18n.getMessage("managercareer_tab") }}</a></li>
  {% endif %}
  <li><a href="#history" data-toggle="tab" class="ajaxLink"
  	data-ajaxtarget="historycontent" data-ajaxblock="user-history" data-ajaxquerystr="userid={{ user.id }}">{{ i18n.getMessage("history_tab") }}</a></li>
  
</ul>

<div class="tab-content">
  <div class="tab-pane active" id="general">
  
  	{% if user.id == env.user.id %}
  	<p><a href="{{ env.getInternalUrl("profile") }}" class="btn"><i class="icon-edit"></i> {{ i18n.getMessage("button_edit") }}</a></p>
  	{% endif %}
  
	<div class="row-fluid">
		<div class="span6">
			{% if userteams|length > 1 %}
				{% set team = "<ul class=\"unstyled\">" %}
				{% for userteam in userteams %}
					{% set team = team ~ "<li><a href=\"" ~ env.getInternalUrl("team", "id=" ~ userteam.id) ~ "\">" ~ userteam.name|e ~ "</a></li>" %}
				{% endfor %}
				{% set team = team ~ "</ul>" %}
			{% elseif userteams|length == 1 %}
				{% set team = "<a href=\"" ~ env.getInternalUrl("team", "id=" ~ userteams[0].id) ~ "\">" ~ userteams[0].name|e ~ "</a>" %}
			{% else %}
				{% set team = "-" %}
			{% endif %}
			
			{{ profile.infofield(i18n.getMessage("entity_club"), team, true) }}
			
			{% if user.nationalteam is defined %}
				{% set nationalteam = "<a href=\"" ~ env.getInternalUrl("team", "id=" ~ user.nationalteam.id) ~ "\">" ~ user.nationalteam.name|e ~ "</a>" %}
				{{ profile.infofield(i18n.getMessage("nationalteams_team_label"), nationalteam, true) }}
			{% endif %}
			
			{{ profile.infofield(i18n.getMessage("entity_users_highscore"), user.highscore) }}
			{{ profile.infofield(i18n.getMessage("entity_users_reputation"), user.reputation) }}
			{{ profile.infofield(i18n.getMessage("entity_users_fanbeliebtheit"), user.popularity ~ "%") }}
			{{ profile.infofield(i18n.getMessage("entity_users_datum_anmeldung"), env.getFormattedDate(user.registration_date)) }}
			{{ profile.infofield(i18n.getMessage("entity_users_lastonline"), env.getFormattedDate(user.lastonline)) }}
		</div>
		<div class="span6">
		
		{% if user.name|length > 0 %}
			{{ profile.infofield(i18n.getMessage("entity_users_name"), user.name) }}
		{% endif %}
		{% if user.place|length > 0 %}
			{{ profile.infofield(i18n.getMessage("entity_users_wohnort"), user.place) }}
		{% endif %}
		{% if user.country|length > 0 %}
			{{ profile.infofield(i18n.getMessage("entity_users_land"), user.country) }}
		{% endif %}
		{% if user.birthday > 0 %}
			{{ profile.infofield(i18n.getMessage("entity_users_geburtstag"), user.birthday|date(env.getConfig("date_format"))) }}
		{% endif %}
		{% if user.occupation|length > 0 %}
			{{ profile.infofield(i18n.getMessage("entity_users_beruf"), user.occupation) }}
		{% endif %}
		{% if user.interests|length > 0 %}
			{{ profile.infofield(i18n.getMessage("entity_users_interessen"), user.interests) }}
		{% endif %}
		{% if user.favorite_club|length > 0 %}
			{{ profile.infofield(i18n.getMessage("entity_users_lieblingsverein"), user.favorite_club) }}
		{% endif %}
		{% if user.homepage|length > 0 %}
		
			{% set websiteLink = "<a href=\"" ~ user.homepage ~ "\" target=\"_blank\">" ~ i18n.getMessage("user_visit_website") ~ "</a>" %}
		
			{{ profile.infofield(i18n.getMessage("entity_users_homepage"), websiteLink, true) }}
		{% endif %}
		</div>
	</div>
  
  </div>
  
  <div class="tab-pane" id="activities">
  	<div id="activitieslist"></div>
  </div>
  
  <div class="tab-pane" id="results">
  	<div id="resultslist"></div>
  </div>
  
  {% if env.getConfig("transfermarket_enabled") or env.getConfig("transferoffers_enabled") %}
  <div class="tab-pane" id="transfers">
  	<div id="transferslist"></div>
  </div>
  {% endif %}
  
  <div class="tab-pane" id="badges">
  	{% if badges|length > 0 %}
  		<table class="table table-striped table-condensed">
  			<thead>
  				<tr>
  					<th>Auszeichnung</th>
  					<th>Beschreibung</th>
  					<th>Status</th>
  					<th>Erhalten</th>
  				</tr>
  			</thead>
  			<tbody>
  			{% for badge in badges %}
  				<tr{% if badge.earned_count < 1 %} class="muted"{% endif %}>
  					<td>
  						{% if badge.earned_count > 0 %}
  							{{ badgesmacros.badge(badge.name, badge.level, badge.last_rewarded) }}
  						{% else %}
  							{{ badgesmacros.badge(badge.name, badge.level) }}
  						{% endif %}
  					</td>
  					<td>
  						{% if badge.description|length and i18n.hasMessage(badge.description) %}
  							{{ i18n.getMessage(badge.description) }}
  						{% else %}
  							{{ badge.description }}
  						{% endif %}
  					</td>
  					<td>
  						{% if badge.event_benchmark > 0 %}
  							{{ badge.current_status|default(0) }}{% if badge.event == 'transfer_master' %}%{% endif %} / {{ badge.event_benchmark }}{% if badge.event == 'transfer_master' %}%{% endif %}
  						{% else %}
  							{{ badge.current_status|default(0) }}
  						{% endif %}
  					</td>
  					<td>{% if badge.earned_count > 0 %}{{ badge.earned_count }}x{% else %}-{% endif %}</td>
  				</tr>
  			{% endfor %}
  			</tbody>
  		</table>
  	{% else %}
  		<p class="muted">Keine Auszeichnungen konfiguriert.</p>
  	{% endif %}
  </div>
  

  {% if career.enabled %}
  <div class="tab-pane" id="managercareer">
   	<div class="row-fluid">
   		<div class="span4">
   			<div class="well">
   				<h4>{{ i18n.getMessage("managercareer_reputation") }}</h4>
   				<p style="font-size: 28px; line-height: 32px;"><strong>{{ career.manager_score }}</strong></p>
   				<p class="muted">{{ i18n.getMessage("managercareer_reputation_help") }}</p>
   				<ul class="unstyled">
   					<li>{{ i18n.getMessage("entity_users_highscore") }}: {{ career.user_highscore }}</li>
   					<li>{{ i18n.getMessage("managercareer_board_average") }}: {% if career.avg_board_satisfaction > 0 %}{{ career.avg_board_satisfaction }}%{% else %}-{% endif %}</li>
   				</ul>
   			</div>
   		</div>
   		<div class="span8">
   			<h4>{{ i18n.getMessage("managercareer_current_teams") }}</h4>
   			{% if career.teams|length > 0 %}
   				<ul>
   				{% for team in career.teams %}
   					<li><a href="{{ env.getInternalUrl("team", "id=" ~ team.id) }}">{{ team.name }}</a> - {{ i18n.getMessage("managercareer_board_satisfaction") }}: {{ team.board_satisfaction }}%</li>
   				{% endfor %}
   				</ul>
   			{% else %}
   				<p class="muted">{{ i18n.getMessage("managercareer_no_current_team") }}</p>
   			{% endif %}
   		</div>
   	</div>

   	{% if career.is_own_profile %}
   		<h4>{{ i18n.getMessage("managercareer_offers_title") }}</h4>
   		{% if career.job_offers_enabled %}
   			{% if career.open_offers|length > 0 %}
   				<table class="table table-striped table-condensed">
   					<thead>
   						<tr>
   							<th>{{ i18n.getMessage("entity_club_name") }}</th>
   							<th>{{ i18n.getMessage("entity_club_liga_id") }}</th>
   							<th>{{ i18n.getMessage("managercareer_club_score") }}</th>
   							<th>{{ i18n.getMessage("managercareer_offer_until") }}</th>
   							<th>&nbsp;</th>
   						</tr>
   					</thead>
   					<tbody>
   					{% for offer in career.open_offers %}
   						<tr>
   							<td>
   								{% if offer.team_picture|length %}
   									<img src="{{ env.getConfig("context_root") }}/uploads/club/{{ offer.team_picture }}" style="max-width: 30px"/>
   								{% endif %}
   								<a href="{{ env.getInternalUrl("team", "id=" ~ offer.team_id) }}">{{ offer.team_name }}</a>
   							</td>
   							<td><a href="{{ env.getInternalUrl("league", "id=" ~ offer.league_id) }}">{{ offer.league_name }}</a></td>
   							<td>{{ offer.club_score }}</td>
   							<td>{{ env.getFormattedDate(offer.expires_date) }}</td>
   							<td>
   								<a href="{{ env.getInternalActionUrl("accept-manager-job", "offerId=" ~ offer.offer_id ~ "&id=" ~ user.id, "user") }}" class="btn btn-small btn-success" onclick="return confirm('{{ i18n.getMessage("managercareer_confirm_accept") }}');"><i class="icon-ok"></i> {{ i18n.getMessage("managercareer_button_accept") }}</a>
   								<a href="{{ env.getInternalActionUrl("decline-manager-job", "offerId=" ~ offer.offer_id ~ "&id=" ~ user.id, "user") }}" class="btn btn-small"><i class="icon-remove"></i> {{ i18n.getMessage("managercareer_button_decline") }}</a>
   							</td>
   						</tr>
   					{% endfor %}
   					</tbody>
   				</table>
   			{% else %}
   				<p class="muted">{{ i18n.getMessage("managercareer_no_open_offers") }}</p>
   			{% endif %}
   		{% else %}
   			<p class="muted">{{ i18n.getMessage("managercareer_offers_disabled") }}</p>
   		{% endif %}

   		<h4>{{ i18n.getMessage("managercareer_freeclubs_title") }}</h4>
   		<p class="muted">{{ i18n.getMessage("managercareer_freeclubs_help") }}</p>
   		{% if career.free_clubs|length > 0 %}
   			<table class="table table-striped table-condensed">
   				<thead>
   					<tr>
   						<th>{{ i18n.getMessage("entity_club_name") }}</th>
   						<th>{{ i18n.getMessage("entity_club_liga_id") }}</th>
   						<th>{{ i18n.getMessage("managercareer_club_score") }}</th>
   						<th>{{ i18n.getMessage("managercareer_required_score") }}</th>
   						<th>{{ i18n.getMessage("managercareer_status") }}</th>
   					</tr>
   				</thead>
   				<tbody>
   				{% for club in career.free_clubs %}
   					<tr{% if not club.eligible %} class="muted"{% endif %}>
   						<td><a href="{{ env.getInternalUrl("team", "id=" ~ club.team_id) }}">{{ club.team_name }}</a></td>
   						<td><a href="{{ env.getInternalUrl("league", "id=" ~ club.league_id) }}">{{ club.league_name }}</a></td>
   						<td>{{ club.club_score }}</td>
   						<td>{{ club.required_score }}</td>
   						<td><span class="label {{ club.career_status_class }}">{% if club.eligible %}{{ i18n.getMessage("managercareer_available") }}{% else %}{{ i18n.getMessage("managercareer_locked") }}{% endif %}</span></td>
   					</tr>
   				{% endfor %}
   				</tbody>
   			</table>
   		{% endif %}
   		<p><a href="{{ env.getInternalUrl("freeclubs") }}" class="btn btn-small"><i class="icon-list"></i> {{ i18n.getMessage("managercareer_show_all_freeclubs") }}</a></p>
   	{% endif %}

   	<h4>{{ i18n.getMessage("managercareer_history_title") }}</h4>
   	{% if career.history|length > 0 %}
   		<table class="table table-striped table-condensed">
   			<thead>
   				<tr>
   					<th>{{ i18n.getMessage("managercareer_date") }}</th>
   					<th>{{ i18n.getMessage("managercareer_old_club") }}</th>
   					<th>{{ i18n.getMessage("managercareer_new_club") }}</th>
   					<th>{{ i18n.getMessage("managercareer_origin") }}</th>
   					<th>{{ i18n.getMessage("managercareer_bonus") }}</th>
   				</tr>
   			</thead>
   			<tbody>
   			{% for item in career.history %}
   				<tr>
   					<td>{{ env.getFormattedDate(item.change_date) }}</td>
   					<td>{% if item.old_team_id > 0 %}<a href="{{ env.getInternalUrl("team", "id=" ~ item.old_team_id) }}">{{ item.old_team_name }}</a>{% else %}-{% endif %}</td>
   					<td><a href="{{ env.getInternalUrl("team", "id=" ~ item.new_team_id) }}">{{ item.new_team_name }}</a></td>
   					<td>{{ i18n.getMessage("managercareer_origin_" ~ item.origin) }}</td>
   					<td>{% if item.highscore_bonus > 0 %}+{{ item.highscore_bonus }}{% else %}-{% endif %}</td>
   				</tr>
   			{% endfor %}
   			</tbody>
   		</table>
   	{% else %}
   		<p class="muted">{{ i18n.getMessage("managercareer_no_history") }}</p>
   	{% endif %}
  </div>
  {% endif %}

  <div class="tab-pane" id="history">
  	<div id="historycontent"></div>
  	
  	{% if user.history|length > 0 %}
  		<h4>{{ i18n.getMessage("entity_users_history") }}</h4>
			{{ user.history|nl2br }}
	{% endif %}
  </div>
</div>

{% endblock %}