{% extends "base.twig" %}

{% block page_title %}
{{ i18n.getMessage("whatchanged_title") }}
{% endblock %}

{% block page_content %}

<h3>{{ i18n.getMessage("whatchanged_title") }}</h3>
<p>{{ i18n.getMessage("whatchanged_intro") }}</p>

{% if not enabled %}
    <div class="alert alert-warning">{{ i18n.getMessage("whatchanged_disabled") }}</div>
{% elseif not human_team %}
    <div class="alert alert-warning">{{ i18n.getMessage("whatchanged_only_human") }}</div>
{% elseif summary is empty %}
    <div class="alert alert-info">
        <i class="icon-info-sign"></i>
        {{ i18n.getMessage("whatchanged_no_summary") }}
    </div>
{% else %}

<h4>{{ i18n.getMessage("whatchanged_current_summary") }}</h4>
<div class="well">
    <h3 style="margin-top: 0;">{{ summary.summary_title }}</h3>
    <p>
        <span class="label {% if summary.data.match.outcome == 'win' %}label-success{% elseif summary.data.match.outcome == 'loss' %}label-important{% else %}label-info{% endif %}">
            {{ i18n.getMessage("whatchanged_" ~ summary.data.match.outcome) }}
        </span>
        {{ summary.data.match.type }}{% if summary.data.match.matchday > 0 %}, {{ summary.data.match.matchday }}. Spieltag{% endif %}
        · {{ summary.match_date|date(env.getConfig("date_format")) }}
    </p>
    <p>
        <a class="btn btn-mini" href="{{ summary.data.match.link }}"><i class="icon-file"></i> {{ i18n.getMessage("whatchanged_match_link") }}</a>
    </p>
</div>

<div class="row-fluid">
    <div class="span6">
        <div class="well">
            <h4>{{ i18n.getMessage("whatchanged_match_result") }}</h4>
            <p><strong>{{ summary.data.match.home_name }} {{ summary.data.match.home_goals }}:{{ summary.data.match.guest_goals }} {{ summary.data.match.guest_name }}</strong></p>
            {% if summary.data.previous_match.available %}
                <small>{{ i18n.getMessage("whatchanged_previous_match") }}: {{ summary.data.previous_match.home_name }} {{ summary.data.previous_match.home_goals }}:{{ summary.data.previous_match.guest_goals }} {{ summary.data.previous_match.guest_name }}</small>
            {% else %}
                <small>{{ i18n.getMessage("whatchanged_no_previous_match") }}</small>
            {% endif %}
        </div>
    </div>
    <div class="span6">
        <div class="well">
            <h4>{{ i18n.getMessage("whatchanged_budget") }}</h4>
            <table class="table table-condensed" style="margin-bottom: 10px;">
                <tbody>
                    <tr>
                        <th style="width: 40%;">{{ i18n.getMessage("whatchanged_budget_before") }}</th>
                        <td style="text-align: right; white-space: nowrap;">{{ summary.data.budget.budget_before|number_format(0, ',', ' ') }} {{ currency }}</td>
                    </tr>
                    <tr>
                        <th>{{ i18n.getMessage("whatchanged_budget_after") }}</th>
                        <td style="text-align: right; white-space: nowrap;">{{ summary.data.budget.budget_after|number_format(0, ',', ' ') }} {{ currency }}</td>
                    </tr>
                    <tr>
                        <th>{{ i18n.getMessage("whatchanged_budget_change") }}</th>
                        <td style="text-align: right; white-space: nowrap;">
                            <span{% if summary.data.budget.change > 0 %} style="color: green;"{% elseif summary.data.budget.change < 0 %} style="color: red;"{% endif %}>
                                {{ summary.data.budget.change > 0 ? '+' : '' }}{{ summary.data.budget.change|number_format(0, ',', ' ') }} {{ currency }}
                            </span>
                        </td>
                    </tr>
                </tbody>
            </table>
            {% if summary.data.budget.entry_count > 0 %}
                <table class="table table-condensed">
                    <tbody>
                    {% for entry in summary.data.budget.entries|slice(0, 5) %}
                        <tr>
                            <td>
                                {% if i18n.hasMessage(entry.subject) %}
                                    {{ i18n.getMessage(entry.subject) }}
                                {% else %}
                                    {{ entry.subject }}
                                {% endif %}
                            </td>
                            <td style="text-align: right; white-space: nowrap; width: 130px;">{{ entry.amount > 0 ? '+' : '' }}{{ entry.amount|number_format(0, ',', ' ') }} {{ currency }}</td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            {% else %}
                <p><small>{{ i18n.getMessage("whatchanged_budget_no_entries") }}</small></p>
            {% endif %}
        </div>
    </div>
</div>

{% if summary.data.trait_highlights is defined and summary.data.trait_highlights.available %}
<div class="well">
    <h4><i class="icon-star"></i> {{ i18n.getMessage("whatchanged_trait_highlights") }}</h4>
    <table class="table table-striped table-condensed" style="margin-bottom: 0;">
        <thead>
            <tr>
                <th>{{ i18n.getMessage("entity_player") }}</th>
                <th>{{ i18n.getMessage("whatchanged_trait") }}</th>
                <th>{{ i18n.getMessage("whatchanged_trait_reason") }}</th>
            </tr>
        </thead>
        <tbody>
        {% for item in summary.data.trait_highlights.items %}
            <tr>
                <td><a href="{{ item.player_link }}">{{ item.player_name }}</a></td>
                <td>{{ item.trait_label }} <span class="label label-info">{{ item.trait_value }}</span></td>
                <td>{{ item.reason }}</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
</div>
{% endif %}


<div class="row-fluid">
    <div class="span6">
        <div class="well">
            <h4>{{ i18n.getMessage("whatchanged_training") }}</h4>
            {% if summary.data.training.available %}
                <dl class="dl-horizontal">
                    <dt>{{ i18n.getMessage("training_navlabel") }}</dt>
                    <dd>{{ summary.data.training.training_type }} ({{ summary.data.training.intensity }}%)</dd>
                    <dt>{{ i18n.getMessage("whatchanged_training_players") }}</dt>
                    <dd>{{ summary.data.training.player_count }}</dd>
                    <dt>{{ i18n.getMessage("whatchanged_training_best_player") }}</dt>
                    <dd>{{ summary.data.training.best_player }}</dd>
                    <dt>{{ i18n.getMessage("whatchanged_training_injuries") }}</dt>
                    <dd>{{ summary.data.training.injuries }}</dd>
                    <dt>{{ i18n.getMessage("whatchanged_training_chemistry") }}</dt>
                    <dd>{{ summary.data.training.old_chemistry }}% / {{ summary.data.training.new_chemistry }}% ({{ summary.data.training.chemistry_change > 0 ? '+' : '' }}{{ summary.data.training.chemistry_change }})</dd>
                </dl>
                {% if summary.data.training.top_effects|length > 0 %}
                    <table class="table table-condensed">
                        <tbody>
                        {% for item in summary.data.training.top_effects %}
                            <tr>
                                <td><a href="{{ env.getInternalUrl('player', 'id=' ~ item.player_id) }}">{{ item.name }}</a></td>
                                <td style="text-align: right; white-space: nowrap;">+{{ item.effect|number_format(3, ',', ' ') }}</td>
                            </tr>
                        {% endfor %}
                        </tbody>
                    </table>
                {% endif %}
            {% else %}
                <p>{{ i18n.getMessage("whatchanged_training_none") }}</p>
            {% endif %}
        </div>
    </div>
    <div class="span6">
        <div class="well">
            <h4>{{ i18n.getMessage("whatchanged_scouting") }}</h4>
            {% if summary.data.scouting.count > 0 %}
                <p><strong>{{ summary.data.scouting.count }}</strong> {{ i18n.getMessage("whatchanged_scouting_new") }}</p>
                <table class="table table-condensed">
                    <tbody>
                    {% for proposal in summary.data.scouting.items %}
                        <tr>
                            <td>
                                <strong>{{ proposal.name }}</strong><br>
                                <small>{{ proposal.age }} Jahre · {{ proposal.position }}{% if proposal.position_main %} / {{ proposal.position_main }}{% endif %} · {{ proposal.reported_strength }}</small>
                            </td>
                            <td style="text-align: right; white-space: nowrap;">{{ proposal.transfer_fee|number_format(0, ',', ' ') }} {{ currency }}</td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
                <p><a class="btn btn-mini" href="{{ env.getInternalUrl('scouting') }}">{{ i18n.getMessage("scouting_navlabel") }}</a></p>
            {% else %}
                <p>{{ i18n.getMessage("whatchanged_scouting_none") }}</p>
            {% endif %}
        </div>
    </div>
</div>

<div class="row-fluid">
    <div class="span4">
        <div class="well">
            <h4>{{ i18n.getMessage("whatchanged_fan_mood") }}</h4>
            {% if summary.data.fan_mood.available %}
                <p><strong>{{ summary.data.fan_mood.old_mood }}% / {{ summary.data.fan_mood.new_mood }}%</strong></p>
                <p>{{ i18n.getMessage("whatchanged_budget_change") }}: <span{% if summary.data.fan_mood.mood_change > 0 %} style="color: green;"{% elseif summary.data.fan_mood.mood_change < 0 %} style="color: red;"{% endif %}>{{ summary.data.fan_mood.mood_change_signed }}</span></p>
                <small>{{ summary.data.fan_mood.reason_key }}</small>
            {% else %}
                <p>{{ i18n.getMessage("whatchanged_fan_no_change") }}</p>
                <p><strong>{{ summary.data.fan_mood.new_mood }}%</strong></p>
            {% endif %}
        </div>
    </div>
    <div class="span4">
        <div class="well">
            <h4>{{ i18n.getMessage("whatchanged_chemistry") }}</h4>
            {% if summary.data.chemistry.available %}
                <p><strong>{{ summary.data.chemistry.old_score }}% / {{ summary.data.chemistry.new_score }}%</strong></p>
                <p>{{ i18n.getMessage("whatchanged_budget_change") }}: <span{% if summary.data.chemistry.change > 0 %} style="color: green;"{% elseif summary.data.chemistry.change < 0 %} style="color: red;"{% endif %}>{{ summary.data.chemistry.change_signed }}</span></p>
                <p>{{ i18n.getMessage("whatchanged_effect") }}: {{ summary.data.chemistry.match_effect }}</p>
            {% else %}
                <p>{{ i18n.getMessage("whatchanged_chemistry_no_change") }}</p>
                <p><strong>{{ summary.data.chemistry.new_score }}%</strong></p>
            {% endif %}
        </div>
    </div>
    <div class="span4">
        <div class="well">
            <h4>{{ i18n.getMessage("whatchanged_board") }}</h4>
            {% if summary.data.board.available %}
                <p><strong>{{ summary.data.board.old }}% / {{ summary.data.board.new }}%</strong></p>
                <p>{{ i18n.getMessage("whatchanged_budget_change") }}: <span{% if summary.data.board.change > 0 %} style="color: green;"{% elseif summary.data.board.change < 0 %} style="color: red;"{% endif %}>{{ summary.data.board.change_signed }}</span></p>
            {% else %}
                <p>{{ i18n.getMessage("whatchanged_board_no_change") }}</p>
                <p><strong>{{ summary.data.board.new }}%</strong></p>
            {% endif %}
        </div>
    </div>
</div>

{% if summary.data.tactical_style is defined and summary.data.tactical_style.available %}
<div class="well">
    <h4>{{ i18n.getMessage("whatchanged_tactical_style") }}</h4>
    <p>
        <strong>{{ i18n.getMessage("tacticalstyle_" ~ summary.data.tactical_style.style) }}</strong>
        <span class="label label-info">{{ i18n.getMessage("formation_tacticalstyle_fit") }}: {{ summary.data.tactical_style.fit }}%</span>
    </p>
    <p>{{ i18n.getMessage("whatchanged_effect") }}: {{ summary.data.tactical_style.effect }}</p>
</div>
{% endif %}

<div class="well">
    <h4>{{ i18n.getMessage("whatchanged_injuries_suspensions") }}</h4>
    {% if summary.data.injuries.count > 0 %}
        <table class="table table-striped table-condensed">
            <thead>
                <tr>
                    <th>{{ i18n.getMessage("entity_player") }}</th>
                    <th>{{ i18n.getMessage("entity_player_verletzt") }}</th>
                    <th>{{ i18n.getMessage("entity_player_gesperrt") }}</th>
                </tr>
            </thead>
            <tbody>
            {% for item in summary.data.injuries.items %}
                <tr>
                    <td><a href="{{ env.getInternalUrl('player', 'id=' ~ item.player_id) }}">{{ item.name }}</a></td>
                    <td>{% if item.current_injury > 0 %}{{ item.current_injury }}{% elseif item.match_injured > 0 %}{{ item.match_injured }}{% else %}-{% endif %}</td>
                    <td>{% if item.current_suspension > 0 %}{{ item.current_suspension }}{% elseif item.red_card %}<span class="label label-important">Rot</span>{% else %}-{% endif %}</td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    {% else %}
        <p>{{ i18n.getMessage("whatchanged_injuries_none") }}</p>
    {% endif %}
</div>

<div class="well">
    <h4>{{ i18n.getMessage("whatchanged_messages_news") }}</h4>
    {% if summary.data.messages_news.message_count == 0 and summary.data.messages_news.news_count == 0 %}
        <p>{{ i18n.getMessage("whatchanged_no_messages_news") }}</p>
    {% else %}
        <div class="row-fluid">
            <div class="span6">
                <h5>{{ i18n.getMessage("whatchanged_messages_new") }}: {{ summary.data.messages_news.message_count }}</h5>
                {% if summary.data.messages_news.messages|length > 0 %}
                    <ul>
                        {% for message in summary.data.messages_news.messages %}
                            <li>{{ message.subject }} <small>{{ message.date|date(env.getConfig("date_format")) }}</small></li>
                        {% endfor %}
                    </ul>
                {% endif %}
            </div>
            <div class="span6">
                <h5>{{ i18n.getMessage("whatchanged_news_new") }}: {{ summary.data.messages_news.news_count }}</h5>
                {% if summary.data.messages_news.news|length > 0 %}
                    <ul>
                        {% for news in summary.data.messages_news.news %}
                            <li>{% if news.link %}<a href="{{ news.link }}">{{ news.title }}</a>{% else %}{{ news.title }}{% endif %} <small>{{ news.date|date(env.getConfig("date_format")) }}</small></li>
                        {% endfor %}
                    </ul>
                {% endif %}
            </div>
        </div>
    {% endif %}
</div>

<div class="well">
    <h4>{{ i18n.getMessage("whatchanged_missions") }}</h4>
    {% if summary.data.missions.available and summary.data.missions.items|length > 0 %}
        <p>
            {{ i18n.getMessage("whatchanged_missions_summary") }}:
            {{ summary.data.missions.summary.completed }} / {{ summary.data.missions.summary.total }}
        </p>
        {% for mission in summary.data.missions.items %}
            <div style="margin-bottom: 12px;">
                <span class="label {{ mission.status_class }} pull-right">{{ mission.status_label }}</span>
                <strong>{{ mission.title }}</strong><br>
                <small>{{ mission.progress_label }} · {{ mission.target_label }}</small>
                <div class="progress" style="margin-top: 6px; margin-bottom: 0;">
                    <div class="bar" style="width: {{ mission.progress_percent }}%;"></div>
                </div>
            </div>
        {% endfor %}
        <p><a class="btn btn-mini" href="{{ env.getInternalUrl('manager-missions') }}">{{ i18n.getMessage("manager-missions_navlabel") }}</a></p>
    {% else %}
        <p>{{ i18n.getMessage("whatchanged_missions_none") }}</p>
    {% endif %}
</div>

<div class="well">
    <h4>{{ i18n.getMessage("whatchanged_recent_summaries") }}</h4>
    {% if recent_summaries|length == 0 %}
        <div class="alert alert-info">{{ i18n.getMessage("whatchanged_no_summary") }}</div>
    {% else %}
        <table class="table table-striped table-condensed" style="margin-bottom: 0;">
            <tbody>
            {% for item in recent_summaries %}
                <tr{% if item.id == summary.id %} class="info"{% endif %}>
                    <td>
                        <a href="{{ item.link }}">{{ item.summary_title }}</a><br>
                        <small>{{ item.match_date|date(env.getConfig("date_format")) }}{% if item.matchday > 0 %} · {{ item.matchday }}. Spieltag{% endif %}</small>
                    </td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    {% endif %}
</div>

{% endif %}

{% endblock %}
